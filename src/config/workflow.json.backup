        "P4-CREATE_RELEASE"
      ],
      "pipeline": [
        "research",
        "ideate",
        "planning",
        "execution_standard",
        "optimize",
        "review",
        "archiving"
      ],
      "overrides": {
        "execution_standard": {
          "mode": "sequential"
        },
        "optimize": {
          "mode": "sequential"
        },
        "review": {
          "mode": "sequential"
        }
      }
    },
    "full": {
      "label": "Full",
      "description": "Complete workflow with automatic loop (Phase 2 uses ralph), multi-model review, and all automation. Openclaw is experimental top-level monitoring.",
      "steps": 56,
      "review_gates": 3,
      "features": {
