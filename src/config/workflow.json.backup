      ],
      "overrides": {}
    }
  },
  "scaffold_profiles": {
    "minimal": {
      "description": "Minimal directory structure for Lite mode",
      "directories": [
        "source",
        "parsed",
        "specs",
        "docs",
        "runtime"
      ],
      "excluded": [
        "source/openspec",
        "reviews",
        "analysis/capability-dependencies.json",
        "analysis/roadmap.json",
        "analysis/global-todo.json",
        "analysis/dependency-graph.json"
      ]
    },
    "full": {
      "description": "Complete directory structure for Standard and Full modes",
      "directories": [
        "source",
        "source/openspec",
        "parsed",
        "analysis",
        "reviews",
        "specs",
        "docs",
        "runtime"
      ],
      "subdirectories": {
        "reviews": [
          "requirements-review",
          "openspec-review",
          "specs-review",
          "final-review"
        ],
        "runtime": [
          "checkpoints",
          "orchestrator"
        ]
      }
    }
  },
  "tool_profiles": {
    "lite": {
      "description": "Basic tools for Lite mode",
      "tools": [
        "basic_parser",
        "spec_builder",
        "shell_runner"
      ],
      "excluded_tools": [
        "ccb",
        "cca",
        "ralph",
        "openspec"
      ]
    },
    "standard": {
      "description": "Standard tools with multi-model review",
      "tools": [
        "basic_parser",
        "spec_builder",
        "shell_runner",
        "ccb",
        "cca",
        "openspec"
      ],
      "excluded_tools": [
        "ralph"
      ]
    },
    "full": {
      "description": "All tools including ralph orchestrator",
      "tools": [
        "basic_parser",
        "spec_builder",
        "shell_runner",
        "ccb",
        "cca",
        "openspec",
        "ralph"
      ],
      "excluded_tools": []
    }
  },
  "core_artifacts": {
    "description": "Core artifacts shared across all modes for upgrade/downgrade compatibility",
    "all_modes": [
      "specs/tasks.json",
      "specs/verification.json",
      "specs/progress.json",
      "docs/TODO.md",
      "runtime/job_state.json"
    ],
    "upgrade_path": {
      "lite_to_standard": {
        "inherited": [
          "specs/tasks.json",
          "specs/progress.json",
          "docs/TODO.md"
        ],
        "generated": [
          "openspec/proposal.md",
          "openspec/tasks.md",
          "openspec/design.md",
          "reviews/",
          "analysis/roadmap.json"
        ]
      },
      "standard_to_full": {
        "inherited": [
          "specs/tasks.json",
          "specs/progress.json",
          "openspec/*.md",
          "reviews/"
        ],
        "generated": [
          "runtime/orchestrator/ralph-events.ndjson",
          "runtime/loop_state.json"
        ]
      }
    },
    "downgrade_path": {
      "full_to_standard": {
        "preserved": [
          "specs/tasks.json",
          "specs/progress.json",
          "openspec/*.md"
        ],
        "ignored": [
          "runtime/orchestrator/",
          "runtime/loop_state.json"
        ]
      },
      "standard_to_lite": {
        "preserved": [
          "specs/tasks.json",
          "specs/progress.json",
          "docs/TODO.md"
        ],
        "ignored": [
          "openspec/",
          "reviews/",
          "analysis/roadmap.json"
        ]
      }
    }
  },
  "mode_invariants": {
    "description": "Enforceable mode-level constraints with unified field structure",
    "lite": {
      "auto_loop": false,
      "openspec_required": false,
      "multi_model_review": false,
      "orchestrator": "user",
      "execution_mode": "manual",
      "decision_source": "conversation",
      "user_confirmation_required": true,
      "human_iteration_required": true
    },
    "standard": {
      "auto_loop": false,
      "openspec_required": true,
      "multi_model_review": true,
      "orchestrator": "user",
      "execution_mode": "manual",
      "decision_source": "workflow",
      "user_confirmation_required": true,
      "human_iteration_required": true
    },
    "full": {
      "auto_loop": true,
      "openspec_required": true,
      "multi_model_review": true,
      "orchestrator": "ralph",
      "execution_mode": "auto",
      "decision_source": "orchestrator",
      "user_confirmation_required": true,
      "human_iteration_required": false
    }
  },
  "_comment_degradation": "Automatic mode downgrade strategy ensures system robustness: Full→Standard (ralph unavailable), Full/Standard→Lite (ccb/cca unavailable). Preserves all artifacts during degradation. Complements the progressive mode design (Lite ⊂ Standard ⊂ Full).",
  "degradation_policy": {
    "description": "Fallback behavior when tools are unavailable",
    "full_degradation": {
      "if_ralph_unavailable": {
        "fallback_to": "standard",
        "behavior": "switch to manual execution, preserve all artifacts"
      },
      "if_ccb_cca_unavailable": {
        "fallback_to": "lite",
        "behavior": "skip multi-model review, use single LLM"
      }
    },
    "standard_degradation": {
      "if_ccb_cca_unavailable": {
        "fallback_to": "lite",
        "behavior": "skip multi-model review, skip OpenSpec generation"
      }
    },
    "lite_degradation": {
      "if_basic_tools_unavailable": {
        "fallback_to": null,
        "behavior": "cannot operate, require manual intervention"
      }
    }
  },
  "observability_profile": {
    "description": "Logging and metrics depth by mode",
    "lite": {
      "log_level": "info",
      "metrics_enabled": false,
      "trace_enabled": false,
      "event_tracking": "minimal"
    },
    "standard": {
      "log_level": "debug",
      "metrics_enabled": true,
      "trace_enabled": false,
      "event_tracking": "standard",
      "review_audit_trail": true
    },
    "full": {
      "log_level": "trace",
      "metrics_enabled": true,
      "trace_enabled": true,
      "event_tracking": "comprehensive",
      "review_audit_trail": true,
      "orchestrator_events": true,
      "concurrency_tracking": true,
      "performance_profiling": true
    }
  },
  "_comment_naming": "Step ID naming convention: P{phase}-{ACTION}_{OBJECT} format (e.g., P0-COLLECT_USER_REQUIREMENT, P1-GENERATE_PLANNING_DOCS). Use semantic IDs for execution, display_id for UI. Standardize on full words (DOCUMENT not DOC, GIT_BRANCH not BRANCH) for consistency. Migration in progress to unify legacy numeric IDs (P0-01) to semantic IDs.",
  "metadata": {
    "owner": "product-builder-cli",
    "created_at": "2026-02-17",
    "job_id_format": "YYYY-MM-DD-HHMM-name",
    "job_root": "exports/jobs/{job_id}/",
    "supported_input_modes": [
      "mdx",
      "ui_form"
    ],
    "tools": {
      "ccb": {
        "description": "Primary LLM CLI for task execution",
        "required_for": [
          "standard",
          "full"
        ]
      },
      "cca": {
        "description": "Secondary LLM CLI for multi-model review",
        "required_for": [
          "standard",
          "full"
        ]
      },
      "ralph": {
        "description": "Phase 2 execution loop controller",
        "required_for": [
          "full"
        ],
        "usage": "Manages automatic task loop in Phase 2"
      },
      "openclaw": {
        "description": "Experimental top-level LLM monitoring (optional)",
        "required_for": [],
        "status": "experimental",
        "usage": "Monitors all tmux terminal windows and unified requirement dispatch",
        "note": "Not yet tested, will be configured last"
      }
    }
  },
  "job_structure": {
    "required_dirs": [
      "exports/jobs/{job_id}/source",
      "exports/jobs/{job_id}/parsed",
      "exports/jobs/{job_id}/analysis",
      "exports/jobs/{job_id}/reviews",
      "exports/jobs/{job_id}/specs"
    ],
    "required_files": [
      "exports/jobs/{job_id}/metadata.json"
    ]
  },
  "review_policy_defaults": {
    "models": [
      "gemini",
      "claude",
      "codex"
    ],
    "pass_threshold": 0.75,
    "max_critical": 0,
    "max_medium": 2,
    "auto_repair": {
      "enabled": true,
      "max_attempts": 3,
      "ask_user_on_exhausted": true,
      "user_options": [
        "continue",
        "cancel"
      ]
    }
  },
  "cli_view": {
    "default_group_by": "phase",
    "show_step_fields": [
      "id",
      "name",
      "skill",
      "condition",
      "review_config"
    ],
    "show_transitions": true
  },
  "_comment_phases_warning": "⚠️ WARNING: The 'phases' array is AUTO-GENERATED from 'phase_registry'. DO NOT EDIT MANUALLY! To modify workflow, edit 'phase_registry' modules and run: node generate-phases-from-registry.js",
  "phases": [
    {
      "id": "phase-0",
      "name": "Requirement Research & Analysis",
      "description": "Comprehensive requirement research and analysis",
      "execution": {
        "mode": "sequential"
      },
      "steps": [
        {
          "id": "P0-COLLECT_USER_REQUIREMENT",
          "name": "Collect User Requirement",
          "description": "Extract scope, constraints, and acceptance hints from user input",
          "input": [
            "user_input.raw"
          ],
          "output": [
            "exports/jobs/{job_id}/source/raw-requirement.txt"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-01"
        },
        {
          "id": "P0-DETECT_REQUIREMENT_TYPE",
          "name": "Detect Requirement Type",
          "description": "Determine whether requirement is brief (one sentence) or detailed (with planning)",
          "input": [
            "exports/jobs/{job_id}/source/raw-requirement.txt"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/requirement-type.json"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-02"
        },
        {
          "id": "P0-REQUIREMENT_CLARIFICATION",
          "name": "Requirement Clarification",
          "description": "Ask about target users, core problems, key features, and constraints",
          "input": [
            "exports/jobs/{job_id}/source/raw-requirement.txt"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/clarified-requirement.md"
          ],
          "condition": "when_requirement_brief",
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-03"
        },
        {
          "id": "P0-REQUIREMENT_EXPANSION",
          "name": "Requirement Expansion",
          "description": "Expand brief requirement into detailed description",
          "input": [
            "exports/jobs/{job_id}/parsed/clarified-requirement.md"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/expanded-requirement.md"
          ],
          "condition": "when_requirement_brief",
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-04"
        },
        {
          "id": "P0-COMPETITOR_RESEARCH",
          "name": "Competitor Research",
          "description": "Use web_search and context7 to find competitors",
          "input": [
            "exports/jobs/{job_id}/parsed/expanded-requirement.md"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/competitor-list.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "optional_tools": [
            "web_search",
            "context7"
          ],
          "display_id": "P0-05"
        },
        {
          "id": "P0-COMPETITOR_ANALYSIS",
          "name": "Competitor Analysis",
          "description": "Analyze feature comparison, pricing, user reviews, and market positioning",
          "input": [
            "exports/jobs/{job_id}/analysis/competitor-list.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/competitor-analysis.md"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-06"
        },
        {
          "id": "P0-MARKET_POSITIONING",
          "name": "Market Positioning",
          "description": "Determine differentiation advantages and target market",
          "input": [
            "exports/jobs/{job_id}/analysis/competitor-analysis.md"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/market-positioning.md"
          ],
          "min_mode": "full",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-07"
        },
        {
          "id": "P0-FEATURE_BREAKDOWN",
          "name": "Feature Breakdown",
          "description": "Break down core features and sub-features",
          "input": [
            "exports/jobs/{job_id}/parsed/expanded-requirement.md"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-08"
        },
        {
          "id": "P0-USER_STORY_GENERATION",
          "name": "User Story Generation",
          "description": "Generate user stories and usage scenarios",
          "input": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/user-stories.md"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-09"
        },
        {
          "id": "P0-TECHNICAL_FEASIBILITY_ANALYSIS",
          "name": "Technical Feasibility Analysis",
          "description": "Evaluate tech stack, dependencies, and risks",
          "input": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/feasibility-analysis.md"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-10"
        },
        {
          "id": "P0-GENERATE_REQUIREMENT_DOCUMENT",
          "name": "Generate Requirement Document",
          "description": "Integrate all analysis results into structured requirement document",
          "input": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json",
            "exports/jobs/{job_id}/analysis/user-stories.md",
            "exports/jobs/{job_id}/analysis/feasibility-analysis.md"
          ],
          "output": [
            "exports/jobs/{job_id}/source/requirement.mdx"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "output_format": "mdx",
          "display_id": "P0-11"
        },
        {
          "id": "P0-REVIEW_REQUIREMENT_DOCUMENT",
          "name": "Review Requirement Document",
          "description": "Multi-model review with auto-repair (up to 3 attempts)",
          "requires_human_approval": true,
          "input": [
            "exports/jobs/{job_id}/source/requirement.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/source/requirement.mdx",
            "exports/jobs/{job_id}/reviews/requirement-review.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb",
            "cca"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          },
          "display_id": "P0-12"
        }
      ],
      "groups": [
        {
          "id": "0.1",
          "name": "Requirement Intake & Clarification",
          "step_ids": [
            "P0-COLLECT_USER_REQUIREMENT",
            "P0-DETECT_REQUIREMENT_TYPE",
            "P0-REQUIREMENT_CLARIFICATION",
            "P0-REQUIREMENT_EXPANSION"
          ]
        },
        {
          "id": "0.2",
          "name": "Market & Competitive Analysis",
          "step_ids": [
            "P0-COMPETITOR_RESEARCH",
            "P0-COMPETITOR_ANALYSIS",
            "P0-MARKET_POSITIONING"
          ]
        },
        {
          "id": "0.3",
          "name": "Feature & Feasibility Analysis",
          "step_ids": [
            "P0-FEATURE_BREAKDOWN",
            "P0-USER_STORY_GENERATION",
            "P0-TECHNICAL_FEASIBILITY_ANALYSIS"
          ]
        },
        {
          "id": "0.4",
          "name": "Requirement Document Generation",
          "step_ids": [
            "P0-GENERATE_REQUIREMENT_DOCUMENT",
            "P0-REVIEW_REQUIREMENT_DOCUMENT"
          ]
        }
      ]
    },
    {
      "id": "phase-1",
      "name": "Planning",
      "description": "Development specification generation and review",
      "execution": {
        "mode": "sequential"
      },
      "steps": [
        {
          "id": "P1-FIND_EXISTING_WORK",
          "name": "Find Existing Work",
          "description": "Discover related jobs, branches, specs, and reusable outputs.",
          "input": [
            "exports/jobs/index.json",
            "repo/specs/**",
            "repo/docs/**"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/existing-work.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-13"
        },
        {
          "id": "P1-UPDATE_CAPABILITY_TREE",
          "name": "Update Capability Tree",
          "description": "Rebuild capability map using build-capability-tree.ts.",
          "input": [
            "repo/specs/**",
            "repo/src/**"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-14"
        },
        {
          "id": "P1-CREATE_JOB",
          "name": "Create Job",
          "description": "Create job directory and metadata file.",
          "input": [
            "CCB_REQ_ID",
            "exports/jobs/{job_id}/analysis/existing-work.json",
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "output": [
            "exports/jobs/{job_id}/metadata.json"
          ],
          "condition": "after_p1_01_and_p1_02",
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-15"
        },
        {
          "id": "P1-CREATE_GIT_BRANCH",
          "name": "Create Git Branch",
          "description": "Create working branch for this job.",
          "input": [
            "exports/jobs/{job_id}/metadata.json"
          ],
          "output": [
            "git.branch.name"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "display_id": "P1-16"
        },
        {
          "id": "P1-CONVERT_REQUIREMENTS_TO_OPENSPEC",
          "name": "Convert Requirements to OpenSpec Format",
          "description": "Transform requirement document into OpenSpec format (proposal, tasks, design)",
          "input": [
            "exports/jobs/{job_id}/source/requirements.mdx",
            "exports/jobs/{job_id}/metadata.json"
          ],
          "output": [
            "exports/jobs/{job_id}/source/openspec/proposal.md",
            "exports/jobs/{job_id}/source/openspec/tasks.md",
            "exports/jobs/{job_id}/source/openspec/design.md"
          ],
          "min_mode": "lite",
          "required_tools": [
            "openspec"
          ],
          "display_id": "P1-17"
        },
        {
          "id": "P1-REVIEW_OPENSPEC_DOCUMENTS",
          "name": "Review OpenSpec Documents",
          "description": "Run multi-model review gate and auto-repair for OpenSpec quality",
          "input": [
            "exports/jobs/{job_id}/source/openspec/proposal.md",
            "exports/jobs/{job_id}/source/openspec/tasks.md",
            "exports/jobs/{job_id}/source/openspec/design.md"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/openspec-review.json"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          },
          "min_mode": "standard",
          "required_tools": [
            "ccb",
            "cca",
            "openspec"
          ],
          "display_id": "P1-18"
        },
        {
          "id": "P1-PARSE_OPENSPEC_TO_STRUCTURED",
          "name": "Parse OpenSpec to Structured Data",
          "description": "Extract structured requirement docs from OpenSpec files",
          "input": [
            "exports/jobs/{job_id}/source/openspec/proposal.md",
            "exports/jobs/{job_id}/source/openspec/tasks.md",
            "exports/jobs/{job_id}/source/openspec/design.md"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/docs.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "openspec"
          ],
          "display_id": "P1-19"
        },
        {
          "id": "P1-CHECK_OR_INFER_FORMJSON",
          "name": "Check or Infer form.json",
          "description": "Use existing form.json when valid, otherwise infer it.",
          "input": [
            "exports/jobs/{job_id}/parsed/docs.json",
            "source/form.json"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/form.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-19"
        },
        {
          "id": "P1-MERGE_TO_UNIFIEDJSON",
          "name": "Merge to unified.json",
          "description": "Merge docs.json and form.json into one execution model.",
          "input": [
            "exports/jobs/{job_id}/parsed/docs.json",
            "exports/jobs/{job_id}/parsed/form.json"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/unified.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-20"
        },
        {
          "id": "P1-ANALYZE_CAPABILITY_DEPENDENCIES",
          "name": "Analyze Capability Dependencies",
          "description": "Map feature requirements to capabilities and dependency graph.",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/capability-dependencies.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-21"
        },
        {
          "id": "P1-GENERATE_DEVELOPMENT_SPECS",
          "name": "Generate Development Specs",
          "description": "Generate structured specs for development (README + JSON files for ralph automation)",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/capability-dependencies.json"
          ],
          "output": [
            "exports/jobs/{job_id}/specs/README.md",
            "exports/jobs/{job_id}/specs/tasks.json",
            "exports/jobs/{job_id}/specs/verification.json",
            "exports/jobs/{job_id}/specs/progress.json"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-22"
        },
        {
          "id": "P1-REVIEW_DEVELOPMENT_SPECS",
          "name": "Review Development Specs",
          "description": "Run multi-model quality gate and auto-repair for generated specs",
          "input": [
            "exports/jobs/{job_id}/specs/README.md",
            "exports/jobs/{job_id}/specs/tasks.json",
            "exports/jobs/{job_id}/specs/verification.json",
            "exports/jobs/{job_id}/specs/progress.json"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/specs-review.json"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          },
          "min_mode": "standard",
          "required_tools": [
            "ccb",
            "cca"
          ],
          "display_id": "P1-23"
        },
        {
          "id": "P1-GENERATE_GLOBAL_ROADMAP_VIEW",
          "name": "Generate Global Roadmap View",
          "description": "Build cross-capability planning graph, milestones, and global todo list",
          "input": [
            "exports/jobs/{job_id}/analysis/capability-dependencies.json",
            "exports/jobs/{job_id}/specs/tasks.json",
            "exports/jobs/{job_id}/specs/verification.json",
            "exports/jobs/{job_id}/specs/progress.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/roadmap.json",
            "exports/jobs/{job_id}/analysis/global-todo.json",
            "exports/jobs/{job_id}/analysis/dependency-graph.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-24"
        },
        {
          "id": "P1-GENERATE_PLANNING_DOCS",
          "name": "Generate Planning Docs",
          "description": "Render planning documents from JSON to Markdown (ROADMAP, TODO, DEPENDENCIES)",
          "input": [
            "exports/jobs/{job_id}/analysis/roadmap.json",
            "exports/jobs/{job_id}/analysis/global-todo.json",
            "exports/jobs/{job_id}/analysis/dependency-graph.json"
          ],
          "output": [
            "exports/jobs/{job_id}/docs/ROADMAP.md",
            "exports/jobs/{job_id}/docs/TODO.md",
            "exports/jobs/{job_id}/docs/DEPENDENCIES.md"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-25"
        },
        {
          "id": "P1-COMMIT_PLANNING_CHANGES",
          "name": "Commit Planning Changes",
          "description": "Commit planning artifacts to job branch.",
          "input": [
            "exports/jobs/{job_id}/**",
            "git.branch.name"
          ],
          "output": [
            "git.commit.planning"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "display_id": "P1-26"
        },
        {
          "id": "P1-REVIEW_PLANNING_RESULTS",
          "name": "Review Planning Results",
          "description": "User reviews planning artifacts and decides whether to proceed with execution.",
          "input": [
            "exports/jobs/{job_id}/docs/ROADMAP.md",
            "exports/jobs/{job_id}/docs/TODO.md",
            "exports/jobs/{job_id}/docs/DEPENDENCIES.md",
            "exports/jobs/{job_id}/specs/README.md",
            "exports/jobs/{job_id}/specs/tasks.json",
            "exports/jobs/{job_id}/analysis/roadmap.json"
          ],
          "output": [
            "user_decision.proceed"
          ],
          "requires_human_approval": true,
          "min_mode": "lite",
          "display_id": "P1-27"
        }
      ],
      "groups": [
        {
          "id": "1.1",
          "name": "Project Context Discovery",
          "step_ids": [
            "P1-FIND_EXISTING_WORK",
            "P1-UPDATE_CAPABILITY_TREE",
            "P1-CREATE_JOB",
            "P1-CREATE_GIT_BRANCH"
          ]
        },
        {
          "id": "1.2",
          "name": "OpenSpec Generation & Review",
          "step_ids": [
            "P1-CONVERT_REQUIREMENTS_TO_OPENSPEC",
            "P1-REVIEW_OPENSPEC_DOCUMENTS",
            "P1-PARSE_OPENSPEC_TO_STRUCTURED"
          ]
        },
        {
          "id": "1.3",
          "name": "Implementation Planning",
          "step_ids": [
            "P1-CHECK_OR_INFER_FORMJSON",
            "P1-MERGE_TO_UNIFIEDJSON",
            "P1-ANALYZE_CAPABILITY_DEPENDENCIES",
            "P1-GENERATE_DEVELOPMENT_SPECS",
            "P1-REVIEW_DEVELOPMENT_SPECS",
            "P1-GENERATE_GLOBAL_ROADMAP_VIEW",
            "P1-GENERATE_PLANNING_DOCS",
            "P1-COMMIT_PLANNING_CHANGES",
            "P1-REVIEW_PLANNING_RESULTS"
          ]
        }
      ]
    },
    {
      "id": "phase-2",
      "name": "Execution",
      "description": "Full task execution loop",
      "execution": {
        "mode": "loop",
        "entry_step": "P2-START_EXECUTION_DECISION"
      },
      "steps": [
        {
          "id": "P2-START_EXECUTION_DECISION",
          "name": "Start Execution Decision",
          "description": "User decides whether to start execution or wait.",
          "input": [
            "exports/jobs/{job_id}/docs/roadmap.mdx",
            "user_decision.proceed"
          ],
          "output": [
            "execution.started"
          ],
          "requires_human_approval": true,
          "min_mode": "lite",
          "display_id": "P2-31"
        },
        {
          "id": "P2-CREATE_GITHUB_ISSUE",
          "name": "Create GitHub Issue",
          "description": "Create GitHub issue to track this job. Link issue to branch and record issue number.",
          "input": [
            "exports/jobs/{job_id}/metadata.json",
            "git.branch.name",
            "exports/jobs/{job_id}/docs/roadmap.mdx"
          ],
          "output": [
            "github.issue.number",
            "github.issue.url"
          ],
          "min_mode": "standard",
          "required_tools": [
            "gh"
          ],
          "display_id": "P2-32"
        },
        {
          "id": "P2-GET_NEXT_TASK",
          "name": "Get Next Task",
          "description": "Retrieve next executable task from queue, checking blockedBy dependencies.",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/progress.json"
          ],
          "output": [
            "tasks.current"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P2-33"
        },
        {
          "id": "P2-EXECUTE_TASK",
          "name": "Execute Task",
          "description": "AI Agent implements the current task.",
          "input": [
            "tasks.current",
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "output": [
            "workspace.code_changes"
          ],
          "condition": "has_executable_task",
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P2-34"
        }
      ],
      "groups": [
        {
          "id": "2.1",
          "name": "Execution Initialization",
          "step_ids": [
            "P2-START_EXECUTION_DECISION",
            "P2-CREATE_GITHUB_ISSUE",
            "P2-GET_NEXT_TASK",
            "P2-EXECUTE_TASK"
          ]
        }
      ]
    },
    {
      "id": "phase-3",
      "name": "Acceptance",
      "description": "Final review and auto-repair",
      "execution": {
        "mode": "loop"
      },
      "steps": [
        {
          "id": "P2-RUN_AUTOMATED_TESTS",
          "name": "Run Automated Tests",
          "description": "Run automated tests using testing frameworks (Jest, Vitest, Playwright, etc.) from verification.json.",
          "input": [
            "workspace.code_changes",
            "exports/jobs/{job_id}/specs/verification.json"
          ],
          "output": [
            "test.results"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P2-35"
        },
        {
          "id": "P2-MULTIMODEL_CODE_REVIEW",
          "name": "Multi-Model Code Review",
          "description": "Review code logic and quality using multiple AI models (gemini, claude, codex).",
          "input": [
            "workspace.code_changes",
            "test.results"
          ],
          "output": [
            "review.results"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          },
          "display_id": "P2-36"
        },
        {
          "id": "P2-FIX_ISSUE",
          "name": "Fix Issue",
          "description": "Fix issues found during testing. Add comment to GitHub Issue tracking the fix attempt.",
          "input": [
            "test.results",
            "workspace.code_changes",
            "github.issue.number"
          ],
          "output": [
            "workspace.code_changes"
          ],
          "condition": "test_failed",
          "min_mode": "lite",
          "required_tools": [
            "gh"
          ],
          "display_id": "P2-37"
        },
        {
          "id": "P2-UPDATE_SPECIFICATION_DOCUMENT",
          "name": "Update Specification Document",
          "description": "Mark task as completed in specification",
          "input": [
            "tasks.current",
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "condition": "test_passed",
          "min_mode": "standard",
          "required_tools": [
            "openspec"
          ],
          "display_id": "P2-38"
        },
        {
          "id": "P2-UPDATE_PROGRESS",
          "name": "Update Progress",
          "description": "Update progress.json with task completion status.",
          "input": [
            "tasks.current",
            "exports/jobs/{job_id}/analysis/progress.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/progress.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P2-39"
        },
        {
          "id": "P2-COMMIT_TASK",
          "name": "Commit Task",
          "description": "Commit task changes to job branch (frontend/backend/OpenSpec).",
          "input": [
            "workspace.code_changes",
            "exports/jobs/{job_id}/source/openspec.mdx",
            "exports/jobs/{job_id}/analysis/progress.json"
          ],
          "output": [
            "git.commit.task"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "requires_human_approval": true,
          "approval": {
            "when": "before_execute",
            "reason": "commit_boundary",
            "modes": [
              "lite",
              "standard"
            ]
          },
          "display_id": "P2-40"
        },
        {
          "id": "P3-FINAL_REVIEW",
          "name": "Final Review",
          "description": "Multi-model review gate for final acceptance of all completed work.",
          "input": [
            "workspace.all_changes",
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/final-review.json"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true,
              "user_options": [
                "retry_phase2",
                "continue"
              ]
            }
          },
          "min_mode": "standard",
          "required_tools": [
            "ccb",
            "cca"
          ],
          "display_id": "P3-41"
        },
        {
          "id": "P3-AGGREGATE_REVIEW_RESULTS",
          "name": "Aggregate Review Results",
          "description": "Aggregate multi-model review results and calculate pass rate.",
          "input": [
            "exports/jobs/{job_id}/reviews/final-review.json"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/final-review-aggregated.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P3-42"
        },
        {
          "id": "P3-FIX_ISSUES",
          "name": "Fix Issues",
          "description": "Fix issues found in final review (max 3 attempts). Add comment to GitHub Issue tracking the fix attempt. If exhausted, return to Phase 2.",
          "input": [
            "exports/jobs/{job_id}/reviews/final-review-aggregated.json",
            "workspace.all_changes",
            "github.issue.number"
          ],
          "output": [
            "workspace.all_changes"
          ],
          "condition": "review_needs_fix",
          "min_mode": "standard",
          "required_tools": [
            "gh"
          ],
          "display_id": "P3-43"
        }
      ],
      "groups": [
        {
          "id": "3.1",
          "name": "Automated Testing",
          "step_ids": [
            "P2-RUN_AUTOMATED_TESTS",
            "P2-MULTIMODEL_CODE_REVIEW",
            "P2-FIX_ISSUE",
            "P2-UPDATE_SPECIFICATION_DOCUMENT",
            "P2-UPDATE_PROGRESS",
            "P2-COMMIT_TASK"
          ]
        },
        {
          "id": "3.2",
          "name": "Final Quality Gate",
          "step_ids": [
            "P3-FINAL_REVIEW",
            "P3-AGGREGATE_REVIEW_RESULTS",
            "P3-FIX_ISSUES"
          ]
        }
      ]
    },
    {
      "id": "phase-4",
      "name": "Review",
      "description": "Human confirmation and PR creation",
      "execution": {
        "mode": "sequential"
      },
      "steps": [
        {
          "id": "P3-RECORD_TECHNICAL_DEBT",
          "name": "Record Technical Debt",
          "description": "Record issues to TECHNICAL_DEBT.md if review passed with minor issues.",
          "input": [
            "exports/jobs/{job_id}/reviews/final-review-aggregated.json"
          ],
          "output": [
            "exports/jobs/{job_id}/TECHNICAL_DEBT.md"
          ],
          "condition": "review_passed_with_issues",
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P3-44"
        },
        {
          "id": "P3-HUMAN_FINAL_CONFIRMATION",
          "name": "Human Final Confirmation",
          "description": "Final human approval to proceed with archiving and deployment. Only executed after machine review passes.",
          "input": [
            "exports/jobs/{job_id}/reviews/final-review-aggregated.json",
            "exports/jobs/{job_id}/TECHNICAL_DEBT.md",
            "workspace.all_changes"
          ],
          "output": [
            "human_approval.final"
          ],
          "requires_human_approval": true,
          "condition": "review_passed",
          "min_mode": "lite",
          "display_id": "P3-45"
        },
        {
          "id": "P3-CREATE_PULL_REQUEST",
          "name": "Create Pull Request",
          "description": "Create GitHub Pull Request for code review. Link to issue and include review results.",
          "input": [
            "git.branch.name",
            "github.issue.number",
            "exports/jobs/{job_id}/reviews/final-review-aggregated.json",
            "exports/jobs/{job_id}/TECHNICAL_DEBT.md"
          ],
          "output": [
            "github.pr.number",
            "github.pr.url"
          ],
          "min_mode": "standard",
          "required_tools": [
            "gh"
          ],
          "display_id": "P3-46"
        }
      ],
      "groups": [
        {
          "id": "3.2",
          "name": "Human Approval Gate",
          "step_ids": []
        },
        {
          "id": "3.3",
          "name": "Pull Request Creation",
          "step_ids": []
        },
        {
          "id": "3.1",
          "name": "Final Review & PR Creation",
          "step_ids": [
            "P3-RECORD_TECHNICAL_DEBT",
            "P3-HUMAN_FINAL_CONFIRMATION",
            "P3-CREATE_PULL_REQUEST"
          ]
        }
      ]
    },
    {
      "id": "phase-5",
      "name": "Archiving",
      "description": "Archive, update documentation, and release",
      "execution": {
        "mode": "sequential"
      },
      "steps": [
        {
          "id": "P4-MERGE_GIT_BRANCH",
          "name": "Merge Git Branch",
          "description": "Merge feature branch to main (frontend + backend).",
          "input": [
            "git.branch.name",
            "human_approval.final"
          ],
          "output": [
            "git.merge.result"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "display_id": "P4-47"
        },
        {
          "id": "P4-ARCHIVE_SPECIFICATION_DOCUMENT",
          "name": "Archive Specification Document",
          "description": "Archive specification document to repository",
          "input": [
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "output": [
            "openspec.archived_path"
          ],
          "min_mode": "standard",
          "required_tools": [
            "openspec"
          ],
          "display_id": "P4-48"
        },
        {
          "id": "P4-COMMIT_ARCHIVE",
          "name": "Commit Archive",
          "description": "Commit archived OpenSpec to openspec repository.",
          "input": [
            "openspec.archived_path"
          ],
          "output": [
            "git.commit.archive"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "display_id": "P4-49"
        },
        {
          "id": "P4-UPDATE_SPECS",
          "name": "Update Specs",
          "description": "Apply changes to capability specifications in specs/.",
          "input": [
            "exports/jobs/{job_id}/specs/*.mdx",
            "repo/specs/**"
          ],
          "output": [
            "repo/specs/**"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P4-50"
        },
        {
          "id": "P4-COMMIT_SPECS",
          "name": "Commit Specs",
          "description": "Commit updated specs to waoooo-docs repository.",
          "input": [
            "repo/specs/**"
          ],
          "output": [
            "git.commit.specs"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "display_id": "P4-51"
        },
        {
          "id": "P4-UPDATE_DEVELOPMENT_DOCS",
          "name": "Update Development Docs",
          "description": "Generate and update capability documentation.",
          "input": [
            "repo/specs/**"
          ],
          "output": [
            "repo/docs/**"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P4-52"
        },
        {
          "id": "P4-COMMIT_DOCS",
          "name": "Commit Docs",
          "description": "Commit updated documentation to waoooo-docs repository.",
          "input": [
            "repo/docs/**"
          ],
          "output": [
            "git.commit.docs"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "display_id": "P4-53"
        },
        {
          "id": "P4-UPDATE_ROADMAP_DOCS",
          "name": "Update Roadmap Docs",
          "description": "Update planning documents (JSON → MDX final state).",
          "input": [
            "exports/jobs/{job_id}/analysis/roadmap.json"
          ],
          "output": [
            "repo/docs/roadmap/**"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P4-54"
        },
        {
          "id": "P4-COMMIT_ROADMAP",
          "name": "Commit Roadmap",
          "description": "Commit updated roadmap documents to waoooo-docs repository.",
          "input": [
            "repo/docs/roadmap/**"
          ],
          "output": [
            "git.commit.roadmap"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "display_id": "P4-55"
        },
        {
          "id": "P4-REBUILD_CAPABILITY_TREE",
          "name": "Rebuild Capability Tree",
          "description": "Rebuild capability tree using build-capability-tree.ts.",
          "input": [
            "repo/specs/**",
            "repo/src/**"
          ],
          "output": [
            "repo/capability-tree.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P4-56"
        },
        {
          "id": "P4-COMMIT_CAPABILITY_TREE",
          "name": "Commit Capability Tree",
          "description": "Commit updated capability tree to waoooo-web repository.",
          "input": [
            "repo/capability-tree.json"
          ],
          "output": [
            "git.commit.capability_tree"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "display_id": "P4-57"
        },
        {
          "id": "P4-CREATE_RELEASE",
          "name": "Create Release",
          "description": "Create GitHub Release with changelog and version tag.",
          "input": [
            "github.pr.number",
            "git.merge.result",
            "exports/jobs/{job_id}/metadata.json"
          ],
          "output": [
            "github.release.tag",
            "github.release.url"
          ],
          "min_mode": "standard",
          "required_tools": [
            "gh"
          ],
          "display_id": "P4-58"
        }
      ],
      "groups": [
        {
          "id": "4.1",
          "name": "Code Integration & Archival",
          "step_ids": []
        },
        {
          "id": "4.2",
          "name": "Knowledge Base Synchronization",
          "step_ids": []
        },
        {
          "id": "4.3",
          "name": "System Capabilities Update",
          "step_ids": []
        },
        {
          "id": "4.4",
          "name": "Release Publication",
          "step_ids": []
        },
        {
          "id": "4.1",
          "name": "Code Integration",
          "step_ids": [
            "P4-MERGE_GIT_BRANCH"
          ]
        },
        {
          "id": "4.2",
          "name": "Documentation Updates",
          "step_ids": [
            "P4-ARCHIVE_SPECIFICATION_DOCUMENT",
            "P4-COMMIT_ARCHIVE",
            "P4-UPDATE_SPECS",
            "P4-COMMIT_SPECS",
            "P4-UPDATE_DEVELOPMENT_DOCS",
            "P4-COMMIT_DOCS",
            "P4-UPDATE_ROADMAP_DOCS",
            "P4-COMMIT_ROADMAP"
          ]
        },
        {
          "id": "4.3",
          "name": "System Updates & Release",
          "step_ids": [
            "P4-REBUILD_CAPABILITY_TREE",
            "P4-COMMIT_CAPABILITY_TREE",
            "P4-CREATE_RELEASE"
          ]
        }
      ]
    }
  ],
  "transitions": [
    {
      "from": "P0-COLLECT_USER_REQUIREMENT",
      "to": "P0-DETECT_REQUIREMENT_TYPE"
    },
    {
      "from": "P0-DETECT_REQUIREMENT_TYPE",
      "to": "P0-REQUIREMENT_CLARIFICATION",
      "condition": "input_mode == 'ui_form'",
      "enabled_in_modes": [
        "standard",
        "full"
      ]
    },
    {
      "from": "P0-DETECT_REQUIREMENT_TYPE",
      "to": "P0-REQUIREMENT_EXPANSION",
      "condition": "input_mode == 'mdx'",
      "enabled_in_modes": [
        "standard",
        "full"
      ]
    },
    {
      "from": "P0-REQUIREMENT_CLARIFICATION",
      "to": "P1-FIND_EXISTING_WORK"
    },
    {
      "from": "P0-REQUIREMENT_CLARIFICATION",
      "to": "P1-UPDATE_CAPABILITY_TREE"
    },
    {
      "from": "P0-REQUIREMENT_EXPANSION",
      "to": "P1-FIND_EXISTING_WORK"
    },
    {
      "from": "P0-REQUIREMENT_EXPANSION",
      "to": "P1-UPDATE_CAPABILITY_TREE"
    },
    {
      "from": "P1-FIND_EXISTING_WORK",
      "to": "P1-CREATE_JOB",
      "condition": "done('P1-02')"
    },
    {
      "from": "P1-UPDATE_CAPABILITY_TREE",
      "to": "P1-CREATE_JOB",
      "condition": "done('P1-01')"
    },
    {
      "from": "P1-CREATE_JOB",
      "to": "P1-CREATE_GIT_BRANCH"
    },
    {
      "from": "P1-CREATE_GIT_BRANCH",
      "to": "P1-CONVERT_REQUIREMENTS_TO_OPENSPEC",
      "enabled_in_modes": [
        "standard",
        "full"
      ]
    },
    {
      "from": "P1-CREATE_GIT_BRANCH",
      "to": "P1-PARSE_MDX_TO_UNIFIED_LITE",
      "enabled_in_modes": [
        "lite"
      ]
    },
    {
      "from": "P1-CONVERT_REQUIREMENTS_TO_OPENSPEC",
      "to": "P1-REVIEW_OPENSPEC_DOCUMENTS"
    },
    {
      "from": "P1-REVIEW_OPENSPEC_DOCUMENTS",
      "to": "P1-PARSE_OPENSPEC_TO_STRUCTURED",
      "condition": "review_passed('P1-05')"
    },
    {
      "from": "P1-PARSE_OPENSPEC_TO_STRUCTURED",
      "to": "P1-CHECK_OR_INFER_FORMJSON"
    },
    {
      "from": "P1-CHECK_OR_INFER_FORMJSON",
      "to": "P1-MERGE_TO_UNIFIEDJSON"
    },
    {
      "from": "P1-MERGE_TO_UNIFIEDJSON",
      "to": "P1-ANALYZE_CAPABILITY_DEPENDENCIES"
    },
    {
      "from": "P1-ANALYZE_CAPABILITY_DEPENDENCIES",
      "to": "P1-GENERATE_DEVELOPMENT_SPECS"
    },
    {
      "from": "P1-GENERATE_DEVELOPMENT_SPECS",
      "to": "P1-REVIEW_DEVELOPMENT_SPECS",
      "enabled_in_modes": [
        "standard",
        "full"
      ]
    },
    {
      "from": "P1-GENERATE_DEVELOPMENT_SPECS",
      "to": "P1-COMMIT_PLANNING_CHANGES",
      "enabled_in_modes": [
        "lite"
      ]
    },
    {
      "from": "P1-REVIEW_DEVELOPMENT_SPECS",
      "to": "P1-GENERATE_GLOBAL_ROADMAP_VIEW",
      "condition": "review_passed('P1-11')"
    },
    {
      "from": "P1-GENERATE_GLOBAL_ROADMAP_VIEW",
      "to": "P1-GENERATE_PLANNING_DOCS"
    },
    {
      "from": "P1-GENERATE_PLANNING_DOCS",
      "to": "P1-COMMIT_PLANNING_CHANGES"
    },
    {
      "from": "P2-START_EXECUTION_DECISION",
      "to": "P2-CREATE_GITHUB_ISSUE"
    },
    {
      "from": "P2-CREATE_GITHUB_ISSUE",
      "to": "P2-GET_NEXT_TASK",
      "enabled_in_modes": [
        "full"
      ]
    },
    {
      "from": "P2-CREATE_GITHUB_ISSUE",
      "to": "P2-EXECUTE_TASK",
      "enabled_in_modes": [
        "lite",
        "standard"
      ]
    },
    {
      "from": "P2-COMMIT_TASK",
      "to": "P2-GET_NEXT_TASK",
      "type": "loop_internal",
      "condition": "has_more_tasks",
      "enabled_in_modes": [
        "full"
      ]
    },
    {
      "from": "P2-COMMIT_TASK",
      "to": "P3-FINAL_REVIEW",
      "type": "forward",
      "condition": "!has_more_tasks",
      "enabled_in_modes": [
        "lite",
        "standard",
        "full"
      ]
    },
    {
      "from": "P2-GET_NEXT_TASK",
      "to": "P3-FINAL_REVIEW",
      "condition": "all_tasks_done",
      "enabled_in_modes": [
        "full"
      ]
    },
    {
      "from": "P3-FINAL_REVIEW",
      "to": "P3-AGGREGATE_REVIEW_RESULTS"
    },
    {
      "from": "P3-AGGREGATE_REVIEW_RESULTS",
      "to": "P3-FIX_ISSUES",
      "condition": "review_needs_fix"
    },
    {
      "from": "P3-AGGREGATE_REVIEW_RESULTS",
      "to": "P3-RECORD_TECHNICAL_DEBT",
      "condition": "review_passed_with_issues"
    },
    {
      "from": "P3-AGGREGATE_REVIEW_RESULTS",
      "to": "P3-HUMAN_FINAL_CONFIRMATION",
      "condition": "review_passed"
    },
    {
      "from": "P3-FIX_ISSUES",
      "to": "P3-FINAL_REVIEW",
      "type": "loop_internal",
      "condition": "retry_review && auto_repair_attempts < 3",
      "enabled_in_modes": [
        "full"
      ]
    },
    {
      "from": "P3-FIX_ISSUES",
      "to": "P2-GET_NEXT_TASK",
      "condition": "max_retries_exhausted && user_chooses_retry_phase2"
    },
    {
      "from": "P3-FIX_ISSUES",
      "to": "P3-RECORD_TECHNICAL_DEBT",
      "condition": "max_retries_exhausted && user_chooses_continue"
    },
    {
      "from": "P3-RECORD_TECHNICAL_DEBT",
      "to": "P3-HUMAN_FINAL_CONFIRMATION"
    },
    {
      "from": "P3-HUMAN_FINAL_CONFIRMATION",
      "to": "P3-CREATE_PULL_REQUEST",
      "condition": "human_approved == true",
      "enabled_in_modes": [
        "standard",
        "full"
      ]
    },
    {
      "from": "P3-HUMAN_FINAL_CONFIRMATION",
      "to": "P4-MERGE_GIT_BRANCH",
      "condition": "human_approved == true",
      "enabled_in_modes": [
        "lite"
      ]
    },
    {
      "from": "P3-HUMAN_FINAL_CONFIRMATION",
      "to": "END",
      "condition": "human_approved == false"
    },
    {
      "from": "P3-CREATE_PULL_REQUEST",
      "to": "P4-MERGE_GIT_BRANCH"
    },
    {
      "from": "P4-MERGE_GIT_BRANCH",
      "to": "P4-ARCHIVE_SPECIFICATION_DOCUMENT",
      "enabled_in_modes": [
        "standard",
        "full"
      ]
    },
    {
      "from": "P4-MERGE_GIT_BRANCH",
      "to": "END",
      "enabled_in_modes": [
        "lite"
      ]
    },
    {
      "from": "P4-ARCHIVE_SPECIFICATION_DOCUMENT",
      "to": "P4-COMMIT_ARCHIVE"
    },
    {
      "from": "P4-COMMIT_ARCHIVE",
      "to": "P4-UPDATE_SPECS"
    },
    {
      "from": "P4-UPDATE_SPECS",
      "to": "P4-COMMIT_SPECS"
    },
    {
      "from": "P4-COMMIT_SPECS",
      "to": "P4-UPDATE_DEVELOPMENT_DOCS"
    },
    {
      "from": "P4-UPDATE_DEVELOPMENT_DOCS",
      "to": "P4-COMMIT_DOCS"
    },
    {
      "from": "P4-COMMIT_DOCS",
      "to": "P4-UPDATE_ROADMAP_DOCS"
    },
    {
      "from": "P4-UPDATE_ROADMAP_DOCS",
      "to": "P4-COMMIT_ROADMAP"
    },
    {
      "from": "P4-COMMIT_ROADMAP",
      "to": "P4-REBUILD_CAPABILITY_TREE"
    },
    {
      "from": "P4-REBUILD_CAPABILITY_TREE",
      "to": "P4-COMMIT_CAPABILITY_TREE"
    },
    {
      "from": "P4-COMMIT_CAPABILITY_TREE",
      "to": "P4-CREATE_RELEASE"
    },
    {
      "from": "P4-CREATE_RELEASE",
      "to": "END"
    }
  ],
  "tool_registry": {
    "ccb": {
      "name": "Claude Code Bridge",
      "package": "@product-builder/ccb",
      "required": true,
      "description": "Multi-model collaboration bridge"
    },
    "cca": {
      "name": "Cross-Claude Agent",
      "package": "@product-builder/cca",
      "required": true,
      "description": "Cross-model agent routing"
    },
    "ralph": {
      "name": "Ralph Retry Loop",
      "package": "@product-builder/ralph",
      "required": false,
      "description": "Automated retry and repair loop"
    },
    "openclaw": {
      "name": "OpenClaw",
      "package": "@product-builder/openclaw",
      "required": false,
      "description": "Advanced code analysis tool"
    }
  },
  "_comment_phase_registry": "Modular step group library. Each module (intake, research, planning, execution, etc.) contains reusable step definitions. Modes compose these modules via 'pipeline' arrays. Variants (e.g., planning_lite, planning_standard, planning) provide mode-specific implementations. This enables flexible workflow assembly and supports upgrade/downgrade between modes.",
  "phase_registry": {
    "intake": {
      "id": "intake",
      "name": "Intake",
      "description": "Quick requirement collection and documentation",
      "execution": {
        "mode": "sequential",
        "orchestrator": "ccb"
      },
      "groups": [],
      "steps": [
        {
          "id": "P0-COLLECT_USER_REQUIREMENT",
          "name": "Collect User Requirement",
          "description": "Extract scope, constraints, and acceptance hints from user input",
          "input": [
            "user_input.raw"
          ],
          "output": [
            "exports/jobs/{job_id}/source/raw-requirement.txt"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-01"
        },
        {
          "id": "P0-DETECT_REQUIREMENT_TYPE",
          "name": "Detect Requirement Type",
          "description": "Determine whether requirement is brief (one sentence) or detailed (with planning)",
          "input": [
            "exports/jobs/{job_id}/source/raw-requirement.txt"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/requirement-type.json"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-02"
        },
        {
          "id": "P0-GENERATE_REQUIREMENT_DOCUMENT",
          "name": "Generate Requirement Document",
          "description": "Integrate all analysis results into structured requirement document",
          "input": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json",
            "exports/jobs/{job_id}/analysis/user-stories.md",
            "exports/jobs/{job_id}/analysis/feasibility-analysis.md"
          ],
          "output": [
            "exports/jobs/{job_id}/source/requirement.mdx"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "output_format": "mdx",
          "display_id": "P0-11"
        },
        {
          "id": "P0-FEATURE_BREAKDOWN",
          "name": "Feature Breakdown",
          "description": "Break down core features and sub-features",
          "input": [
            "exports/jobs/{job_id}/parsed/expanded-requirement.md"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-08",
          "enabled_in_modes": [
            "lite"
          ]
        }
      ]
    },
    "research": {
      "id": "research",
      "name": "Research",
      "description": "Comprehensive requirement research and analysis",
      "execution": {
        "mode": "sequential",
        "orchestrator": "ccb"
      },
      "groups": [
        {
          "id": "0.1",
          "name": "Requirement Intake & Clarification",
          "step_ids": [
            "P0-COLLECT_USER_REQUIREMENT",
            "P0-DETECT_REQUIREMENT_TYPE",
            "P0-REQUIREMENT_CLARIFICATION",
            "P0-REQUIREMENT_EXPANSION"
          ]
        },
        {
          "id": "0.2",
          "name": "Market & Competitive Analysis",
          "step_ids": [
            "P0-COMPETITOR_RESEARCH",
            "P0-COMPETITOR_ANALYSIS",
            "P0-MARKET_POSITIONING"
          ]
        },
        {
          "id": "0.3",
          "name": "Feature & Feasibility Analysis",
          "step_ids": [
            "P0-FEATURE_BREAKDOWN",
            "P0-USER_STORY_GENERATION",
            "P0-TECHNICAL_FEASIBILITY_ANALYSIS"
          ]
        },
        {
          "id": "0.4",
          "name": "Requirement Document Generation",
          "step_ids": [
            "P0-GENERATE_REQUIREMENT_DOCUMENT",
            "P0-REVIEW_REQUIREMENT_DOCUMENT"
          ]
        }
      ],
      "steps": [
        {
          "id": "P0-COLLECT_USER_REQUIREMENT",
          "name": "Collect User Requirement",
          "description": "Extract scope, constraints, and acceptance hints from user input",
          "input": [
            "user_input.raw"
          ],
          "output": [
            "exports/jobs/{job_id}/source/raw-requirement.txt"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-01"
        },
        {
          "id": "P0-DETECT_REQUIREMENT_TYPE",
          "name": "Detect Requirement Type",
          "description": "Determine whether requirement is brief (one sentence) or detailed (with planning)",
          "input": [
            "exports/jobs/{job_id}/source/raw-requirement.txt"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/requirement-type.json"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-02"
        },
        {
          "id": "P0-REQUIREMENT_CLARIFICATION",
          "name": "Requirement Clarification",
          "description": "Ask about target users, core problems, key features, and constraints",
          "input": [
            "exports/jobs/{job_id}/source/raw-requirement.txt"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/clarified-requirement.md"
          ],
          "condition": "when_requirement_brief",
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-03"
        },
        {
          "id": "P0-REQUIREMENT_EXPANSION",
          "name": "Requirement Expansion",
          "description": "Expand brief requirement into detailed description",
          "input": [
            "exports/jobs/{job_id}/parsed/clarified-requirement.md"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/expanded-requirement.md"
          ],
          "condition": "when_requirement_brief",
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-04"
        },
        {
          "id": "P0-COMPETITOR_RESEARCH",
          "name": "Competitor Research",
          "description": "Use web_search and context7 to find competitors",
          "input": [
            "exports/jobs/{job_id}/parsed/expanded-requirement.md"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/competitor-list.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "optional_tools": [
            "web_search",
            "context7"
          ],
          "display_id": "P0-05"
        },
        {
          "id": "P0-COMPETITOR_ANALYSIS",
          "name": "Competitor Analysis",
          "description": "Analyze feature comparison, pricing, user reviews, and market positioning",
          "input": [
            "exports/jobs/{job_id}/analysis/competitor-list.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/competitor-analysis.md"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-06"
        },
        {
          "id": "P0-MARKET_POSITIONING",
          "name": "Market Positioning",
          "description": "Determine differentiation advantages and target market",
          "input": [
            "exports/jobs/{job_id}/analysis/competitor-analysis.md"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/market-positioning.md"
          ],
          "min_mode": "full",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-07"
        },
        {
          "id": "P0-FEATURE_BREAKDOWN",
          "name": "Feature Breakdown",
          "description": "Break down core features and sub-features",
          "input": [
            "exports/jobs/{job_id}/parsed/expanded-requirement.md"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-08"
        },
        {
          "id": "P0-USER_STORY_GENERATION",
          "name": "User Story Generation",
          "description": "Generate user stories and usage scenarios",
          "input": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/user-stories.md"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-09"
        },
        {
          "id": "P0-TECHNICAL_FEASIBILITY_ANALYSIS",
          "name": "Technical Feasibility Analysis",
          "description": "Evaluate tech stack, dependencies, and risks",
          "input": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/feasibility-analysis.md"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P0-10"
        },
        {
          "id": "P0-GENERATE_REQUIREMENT_DOCUMENT",
          "name": "Generate Requirement Document",
          "description": "Integrate all analysis results into structured requirement document",
          "input": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json",
            "exports/jobs/{job_id}/analysis/user-stories.md",
            "exports/jobs/{job_id}/analysis/feasibility-analysis.md"
          ],
          "output": [
            "exports/jobs/{job_id}/source/requirement.mdx"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "output_format": "mdx",
          "display_id": "P0-11"
        },
        {
          "id": "P0-REVIEW_REQUIREMENT_DOCUMENT",
          "name": "Review Requirement Document",
          "description": "Multi-model review with auto-repair (up to 3 attempts)",
          "requires_human_approval": true,
          "input": [
            "exports/jobs/{job_id}/source/requirement.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/source/requirement.mdx",
            "exports/jobs/{job_id}/reviews/requirement-review.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb",
            "cca"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          },
          "display_id": "P0-12"
        }
      ]
    },
    "ideate": {
      "id": "ideate",
      "name": "Ideate",
      "description": "OpenSpec generation and review",
      "execution": {
        "mode": "sequential",
        "orchestrator": "ccb"
      },
      "groups": [
        {
          "id": "1.1",
          "name": "Project Context Discovery",
          "step_ids": [
            "P1-FIND_EXISTING_WORK",
            "P1-UPDATE_CAPABILITY_TREE",
            "P1-CREATE_JOB",
            "P1-CREATE_GIT_BRANCH"
          ]
        },
        {
          "id": "1.2",
          "name": "OpenSpec Generation & Review",
          "step_ids": [
            "P1-CONVERT_REQUIREMENTS_TO_OPENSPEC",
            "P1-REVIEW_OPENSPEC_DOCUMENTS",
            "P1-PARSE_OPENSPEC_TO_STRUCTURED"
          ]
        }
      ],
      "steps": [
        {
          "id": "P1-FIND_EXISTING_WORK",
          "name": "Find Existing Work",
          "description": "Discover related jobs, branches, specs, and reusable outputs.",
          "input": [
            "exports/jobs/index.json",
            "repo/specs/**",
            "repo/docs/**"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/existing-work.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-13"
        },
        {
          "id": "P1-UPDATE_CAPABILITY_TREE",
          "name": "Update Capability Tree",
          "description": "Rebuild capability map using build-capability-tree.ts.",
          "input": [
            "repo/specs/**",
            "repo/src/**"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-14"
        },
        {
          "id": "P1-CREATE_JOB",
          "name": "Create Job",
          "description": "Create job directory and metadata file.",
          "input": [
            "CCB_REQ_ID",
            "exports/jobs/{job_id}/analysis/existing-work.json",
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "output": [
            "exports/jobs/{job_id}/metadata.json"
          ],
          "condition": "after_p1_01_and_p1_02",
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-15"
        },
        {
          "id": "P1-CREATE_GIT_BRANCH",
          "name": "Create Git Branch",
          "description": "Create working branch for this job.",
          "input": [
            "exports/jobs/{job_id}/metadata.json"
          ],
          "output": [
            "git.branch.name"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "display_id": "P1-16"
        },
        {
          "id": "P1-CONVERT_REQUIREMENTS_TO_OPENSPEC",
          "name": "Convert Requirements to OpenSpec Format",
          "description": "Transform requirement document into OpenSpec format (proposal, tasks, design)",
          "input": [
            "exports/jobs/{job_id}/source/requirements.mdx",
            "exports/jobs/{job_id}/metadata.json"
          ],
          "output": [
            "exports/jobs/{job_id}/source/openspec/proposal.md",
            "exports/jobs/{job_id}/source/openspec/tasks.md",
            "exports/jobs/{job_id}/source/openspec/design.md"
          ],
          "min_mode": "lite",
          "required_tools": [
            "openspec"
          ],
          "display_id": "P1-17"
        },
        {
          "id": "P1-REVIEW_OPENSPEC_DOCUMENTS",
          "name": "Review OpenSpec Documents",
          "description": "Run multi-model review gate and auto-repair for OpenSpec quality",
          "input": [
            "exports/jobs/{job_id}/source/openspec/proposal.md",
            "exports/jobs/{job_id}/source/openspec/tasks.md",
            "exports/jobs/{job_id}/source/openspec/design.md"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/openspec-review.json"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          },
          "min_mode": "standard",
          "required_tools": [
            "ccb",
            "cca",
            "openspec"
          ],
          "display_id": "P1-18"
        },
        {
          "id": "P1-PARSE_OPENSPEC_TO_STRUCTURED",
          "name": "Parse OpenSpec to Structured Data",
          "description": "Extract structured requirement docs from OpenSpec files",
          "input": [
            "exports/jobs/{job_id}/source/openspec/proposal.md",
            "exports/jobs/{job_id}/source/openspec/tasks.md",
            "exports/jobs/{job_id}/source/openspec/design.md"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/docs.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "openspec"
          ],
          "display_id": "P1-19"
        }
      ]
    },
    "planning_lite": {
      "id": "planning_lite",
      "name": "Planning",
      "description": "Simplified planning for quick development",
      "execution": {
        "mode": "sequential",
        "orchestrator": "ccb"
      },
      "groups": [],
      "steps": [
        {
          "id": "P1-CREATE_JOB",
          "name": "Create Job",
          "description": "Create job directory and metadata file.",
          "input": [
            "CCB_REQ_ID",
            "exports/jobs/{job_id}/analysis/existing-work.json",
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "output": [
            "exports/jobs/{job_id}/metadata.json"
          ],
          "condition": "after_p1_01_and_p1_02",
          "min_mode": "lite",
          "enabled_in_modes": [
            "lite"
          ],
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-15"
        },
        {
          "id": "P1-CREATE_GIT_BRANCH",
          "name": "Create Git Branch",
          "description": "Create working branch for this job.",
          "input": [
            "exports/jobs/{job_id}/metadata.json"
          ],
          "output": [
            "git.branch.name"
          ],
          "min_mode": "lite",
          "enabled_in_modes": [
            "lite"
          ],
          "required_tools": [
            "git"
          ],
          "display_id": "P1-16"
        },
        {
          "id": "P1-PARSE_MDX_TO_UNIFIED_LITE",
          "name": "Parse MDX to Unified (Lite)",
          "description": "Direct transformation from requirements.mdx to unified.json, bypassing OpenSpec conversion",
          "input": [
            "exports/jobs/{job_id}/source/requirements.mdx",
            "exports/jobs/{job_id}/metadata.json"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/unified.json"
          ],
          "min_mode": "lite",
          "enabled_in_modes": [
            "lite"
          ],
          "required_tools": [
            "basic_parser"
          ],
          "display_id": "P1-28"
        },
        {
          "id": "P1-ANALYZE_CAPABILITIES_LITE",
          "name": "Analyze Capabilities (Lite)",
          "description": "Simplified capability analysis for Lite mode",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/capability-dependencies.json"
          ],
          "min_mode": "lite",
          "enabled_in_modes": [
            "lite"
          ],
          "required_tools": [
            "basic_parser"
          ],
          "display_id": "P1-29"
        },
        {
          "id": "P1-GENERATE_DEVELOPMENT_SPECS",
          "name": "Generate Development Specs",
          "description": "Generate structured specs for development (README + JSON files for ralph automation)",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/capability-dependencies.json"
          ],
          "output": [
            "exports/jobs/{job_id}/specs/README.md",
            "exports/jobs/{job_id}/specs/tasks.json",
            "exports/jobs/{job_id}/specs/verification.json",
            "exports/jobs/{job_id}/specs/progress.json"
          ],
          "min_mode": "lite",
          "enabled_in_modes": [
            "lite"
          ],
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-22"
        },
        {
          "id": "P1-GENERATE_PLANNING_DOCS_LITE",
          "name": "Generate Planning Docs (Lite)",
          "description": "Generate simplified planning documents for Lite mode",
          "input": [
            "exports/jobs/{job_id}/specs/tasks.json",
            "exports/jobs/{job_id}/analysis/capability-dependencies.json"
          ],
          "output": [
            "exports/jobs/{job_id}/docs/TODO.md"
          ],
          "min_mode": "lite",
          "enabled_in_modes": [
            "lite"
          ],
          "required_tools": [
            "basic_parser"
          ],
          "display_id": "P1-30"
        },
        {
          "id": "P1-COMMIT_PLANNING_CHANGES",
          "name": "Commit Planning Changes",
          "description": "Commit planning artifacts to job branch.",
          "input": [
            "exports/jobs/{job_id}/**",
            "git.branch.name"
          ],
          "output": [
            "git.commit.planning"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "display_id": "P1-26"
        }
      ]
    },
    "planning": {
      "id": "planning",
      "name": "Planning",
      "description": "Development specification generation and review",
      "execution": {
        "mode": "sequential_with_parallel_group",
        "orchestrator": "ccb"
      },
      "groups": [
        {
          "id": "1.3",
          "name": "Implementation Planning",
          "step_ids": [
            "P1-CHECK_OR_INFER_FORMJSON",
            "P1-MERGE_TO_UNIFIEDJSON",
            "P1-ANALYZE_CAPABILITY_DEPENDENCIES",
            "P1-GENERATE_DEVELOPMENT_SPECS",
            "P1-REVIEW_DEVELOPMENT_SPECS",
            "P1-GENERATE_GLOBAL_ROADMAP_VIEW",
            "P1-GENERATE_PLANNING_DOCS",
            "P1-COMMIT_PLANNING_CHANGES",
            "P1-REVIEW_PLANNING_RESULTS"
          ]
        }
      ],
      "steps": [
        {
          "id": "P1-CHECK_OR_INFER_FORMJSON",
          "name": "Check or Infer form.json",
          "description": "Use existing form.json when valid, otherwise infer it.",
          "input": [
            "exports/jobs/{job_id}/parsed/docs.json",
            "source/form.json"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/form.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-19"
        },
        {
          "id": "P1-MERGE_TO_UNIFIEDJSON",
          "name": "Merge to unified.json",
          "description": "Merge docs.json and form.json into one execution model.",
          "input": [
            "exports/jobs/{job_id}/parsed/docs.json",
            "exports/jobs/{job_id}/parsed/form.json"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/unified.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-20"
        },
        {
          "id": "P1-ANALYZE_CAPABILITY_DEPENDENCIES",
          "name": "Analyze Capability Dependencies",
          "description": "Map feature requirements to capabilities and dependency graph.",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/capability-dependencies.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-21"
        },
        {
          "id": "P1-GENERATE_DEVELOPMENT_SPECS",
          "name": "Generate Development Specs",
          "description": "Generate structured specs for development (README + JSON files for ralph automation)",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/capability-dependencies.json"
          ],
          "output": [
            "exports/jobs/{job_id}/specs/README.md",
            "exports/jobs/{job_id}/specs/tasks.json",
            "exports/jobs/{job_id}/specs/verification.json",
            "exports/jobs/{job_id}/specs/progress.json"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-22"
        },
        {
          "id": "P1-REVIEW_DEVELOPMENT_SPECS",
          "name": "Review Development Specs",
          "description": "Run multi-model quality gate and auto-repair for generated specs",
          "input": [
            "exports/jobs/{job_id}/specs/README.md",
            "exports/jobs/{job_id}/specs/tasks.json",
            "exports/jobs/{job_id}/specs/verification.json",
            "exports/jobs/{job_id}/specs/progress.json"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/specs-review.json"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          },
          "min_mode": "standard",
          "required_tools": [
            "ccb",
            "cca"
          ],
          "display_id": "P1-23"
        },
        {
          "id": "P1-GENERATE_GLOBAL_ROADMAP_VIEW",
          "name": "Generate Global Roadmap View",
          "description": "Build cross-capability planning graph, milestones, and global todo list",
          "input": [
            "exports/jobs/{job_id}/analysis/capability-dependencies.json",
            "exports/jobs/{job_id}/specs/tasks.json",
            "exports/jobs/{job_id}/specs/verification.json",
            "exports/jobs/{job_id}/specs/progress.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/roadmap.json",
            "exports/jobs/{job_id}/analysis/global-todo.json",
            "exports/jobs/{job_id}/analysis/dependency-graph.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-24"
        },
        {
          "id": "P1-GENERATE_PLANNING_DOCS",
          "name": "Generate Planning Docs",
          "description": "Render planning documents from JSON to Markdown (ROADMAP, TODO, DEPENDENCIES)",
          "input": [
            "exports/jobs/{job_id}/analysis/roadmap.json",
            "exports/jobs/{job_id}/analysis/global-todo.json",
            "exports/jobs/{job_id}/analysis/dependency-graph.json"
          ],
          "output": [
            "exports/jobs/{job_id}/docs/ROADMAP.md",
            "exports/jobs/{job_id}/docs/TODO.md",
            "exports/jobs/{job_id}/docs/DEPENDENCIES.md"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "display_id": "P1-25"
        },
        {
          "id": "P1-COMMIT_PLANNING_CHANGES",
          "name": "Commit Planning Changes",
          "description": "Commit planning artifacts to job branch.",
          "input": [
            "exports/jobs/{job_id}/**",
            "git.branch.name"
          ],
          "output": [
            "git.commit.planning"
          ],
          "min_mode": "lite",
          "required_tools": [
            "git"
          ],
          "display_id": "P1-26"
        },
        {
          "id": "P1-REVIEW_PLANNING_RESULTS",
          "name": "Review Planning Results",
          "description": "User reviews planning artifacts and decides whether to proceed with execution.",
          "input": [
            "exports/jobs/{job_id}/docs/ROADMAP.md",
            "exports/jobs/{job_id}/docs/TODO.md",
            "exports/jobs/{job_id}/docs/DEPENDENCIES.md",
            "exports/jobs/{job_id}/specs/README.md",
            "exports/jobs/{job_id}/specs/tasks.json",
            "exports/jobs/{job_id}/analysis/roadmap.json"
          ],
          "output": [
            "user_decision.proceed"
          ],
          "requires_human_approval": true,
          "min_mode": "lite",
          "display_id": "P1-27"
        }
      ]
    },
    "execution_lite": {
      "id": "execution_lite",
      "name": "Execution",
      "description": "Simple task execution",
      "execution": {
        "mode": "sequential",
        "orchestrator": "user"
      },
      "groups": [],
      "steps": [
        {
          "id": "P2-EXECUTE_TASK",
          "name": "Execute Task",
          "description": "AI Agent implements the current task.",
          "input": [
            "tasks.current",
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "output": [
            "workspace.code_changes"
          ],
          "condition": "has_executable_task",
          "min_mode": "lite",
          "required_tools": [
            "ccb"
