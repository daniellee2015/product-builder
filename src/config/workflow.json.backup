{
  "_comment_structure": "This workflow uses a dual-structure design: (1) 'phases' array provides a unified Phase 0-4 view for UI/progress tracking across all modes, (2) 'phase_registry' object contains modular step groups that are composed via 'pipeline' fields to support three progressive modes (Lite ⊂ Standard ⊂ Full) and enable runtime mode switching/degradation.",
  "schema_version": "2.0",
  "$schema": "https://product-builder.dev/schemas/workflow.v2.json",
  "version": "1.0.0",
  "workflow_id": "product-builder-cli-standard",
  "name": "Product Builder CLI End-to-End Workflow",
  "description": "Five-phase workflow with conditional branching, parallel steps, task-loop execution, and multi-model review auto-repair.",
  "mode": "full",
  "_comment_modes": "Three progressive modes with increasing automation: Lite (16 steps, manual, no OpenSpec/review) ⊂ Standard (51 steps, manual, with OpenSpec/review) ⊂ Full (56 steps, auto-loop via ralph). Each mode uses different 'pipeline' compositions from 'phase_registry' modules. Supports runtime mode switching and automatic degradation when tools are unavailable.",
  "available_modes": {
    "lite": {
      "label": "Lite",
      "description": "Single CLI, minimal workflow, direct MDX to development without OpenSpec conversion",
      "steps": 16,
      "review_gates": 0,
      "features": {
        "openspec_enabled": false,
        "multi_model_review": false,
        "auto_loop": false,
        "directory_scaffolding": "minimal"
      },
      "orchestrator": "user",
      "execution_mode": "manual",
      "loop_policy": "disabled",
      "step_trigger_policy": "manual_each_step",
      "required_tools": [],
      "tool_profile": "lite",
      "scaffold_profile": "minimal",
      "enabled_steps": [
        "P0-COLLECT_USER_REQUIREMENT",
        "P0-DETECT_REQUIREMENT_TYPE",
        "P0-FEATURE_BREAKDOWN",
        "P0-GENERATE_REQUIREMENT_DOCUMENT",
        "P1-CREATE_JOB",
        "P1-CREATE_GIT_BRANCH",
        "P1-PARSE_MDX_TO_UNIFIED_LITE",
        "P1-ANALYZE_CAPABILITIES_LITE",
        "P1-GENERATE_PLANNING_DOCS_LITE",
        "P1-GENERATE_DEVELOPMENT_SPECS",
        "P1-COMMIT_PLANNING_CHANGES",
        "P2-EXECUTE_TASK",
        "P2-COMMIT_TASK",
        "P3-RECORD_TECHNICAL_DEBT",
        "P3-HUMAN_FINAL_CONFIRMATION",
        "P4-MERGE_GIT_BRANCH"
      ],
      "pipeline": [
        "intake",
        "planning_lite",
        "execution_lite",
        "testing_lite",
        "review_lite",
        "archiving_lite"
      ],
      "overrides": {}
    },
    "standard": {
      "label": "Standard",
      "description": "Multi-model review with ccb/cca, manual execution, no automatic loop",
      "steps": 51,
      "review_gates": 3,
      "features": {
        "openspec_enabled": true,
        "multi_model_review": true,
        "auto_loop": false,
        "directory_scaffolding": "full"
      },
      "orchestrator": "user",
      "execution_mode": "manual",
      "loop_policy": "disabled",
      "step_trigger_policy": "manual_each_step",
      "requires_user_iteration": true,
      "required_tools": [
        "ccb",
        "cca"
      ],
      "tool_profile": "standard",
      "scaffold_profile": "full",
      "enabled_steps": [
        "P0-COLLECT_USER_REQUIREMENT",
        "P0-DETECT_REQUIREMENT_TYPE",
        "P0-REQUIREMENT_CLARIFICATION",
        "P0-REQUIREMENT_EXPANSION",
        "P0-FEATURE_BREAKDOWN",
        "P0-USER_STORY_GENERATION",
        "P0-TECHNICAL_FEASIBILITY_ANALYSIS",
        "P0-GENERATE_REQUIREMENT_DOCUMENT",
        "P0-REVIEW_REQUIREMENT_DOCUMENT",
        "P1-FIND_EXISTING_WORK",
