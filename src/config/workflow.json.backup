{
  "$schema": "https://product-builder.dev/schemas/workflow.v1.json",
  "version": "1.0.0",
  "workflow_id": "product-builder-cli-standard",
  "name": "Product Builder CLI End-to-End Workflow",
  "description": "Five-phase workflow with conditional branching, parallel steps, task-loop execution, and multi-model review auto-repair.",
  "mode": "full",
  "available_modes": {
    "full": {
      "label": "Full",
      "required_tools": [
        "ccb",
        "cca",
        "ralph",
        "openclaw"
      ],
      "description": "Complete workflow with multi-model review, Ralph retry loop, auto-repair, and monitoring",
      "steps": 31,
      "review_gates": 3
    },
    "standard": {
      "label": "Standard",
      "required_tools": [
        "ccb",
        "cca"
      ],
      "description": "Multi-model review without auto-retry or monitoring",
      "steps": 26,
      "review_gates": 3
    },
    "lite": {
      "label": "Lite",
      "required_tools": [],
      "description": "Single CLI, minimal workflow, no multi-model review",
      "steps": 12,
      "review_gates": 0
    }
  },
  "metadata": {
    "owner": "product-builder-cli",
    "created_at": "2026-02-17",
    "job_id_format": "YYYY-MM-DD-HHMM-name",
    "job_root": "exports/jobs/{job_id}/",
    "supported_input_modes": [
      "mdx",
      "ui_form"
    ]
  },
  "job_structure": {
    "required_dirs": [
      "exports/jobs/{job_id}/source",
      "exports/jobs/{job_id}/parsed",
      "exports/jobs/{job_id}/analysis",
      "exports/jobs/{job_id}/reviews",
      "exports/jobs/{job_id}/specs"
    ],
    "required_files": [
      "exports/jobs/{job_id}/metadata.json"
    ]
  },
  "review_policy_defaults": {
    "models": [
      "gemini",
      "claude",
      "codex"
    ],
    "pass_threshold": 0.75,
    "max_critical": 0,
    "max_medium": 2,
    "auto_repair": {
      "enabled": true,
      "max_attempts": 3,
      "ask_user_on_exhausted": true,
      "user_options": [
        "continue",
        "cancel"
      ]
    }
  },
  "cli_view": {
    "default_group_by": "phase",
    "show_step_fields": [
      "id",
      "name",
      "skill",
      "condition",
      "review_config"
    ],
    "show_transitions": true
  },
  "phases": [
    {
      "id": "phase-0",
      "name": "Requirement Analysis",
      "description": "Create a normalized MDX requirement source from raw request or UI form input.",
      "execution": {
        "mode": "sequential"
      },
      "steps": [
        {
          "id": "P0-01",
          "name": "Parse Raw Requirement",
          "description": "Extract scope, constraints, and acceptance hints from user request.",
          "skill": "requirement-parse",
          "input": [
            "ccb_request.raw",
            "workspace.context"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/requirement-analysis.json"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P0-02",
          "name": "Detect Input Mode",
          "description": "Determine whether upstream requirement source is MDX or UI form.",
          "skill": "requirement-parse",
          "input": [
            "exports/jobs/{job_id}/parsed/requirement-analysis.json"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/input-mode.json"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P0-03",
          "name": "Generate MDX from Form",
          "description": "Convert UI form payload into canonical requirement MDX.",
          "skill": "form-to-mdx",
          "input": [
            "source/requirement-form.json"
          ],
          "output": [
            "exports/jobs/{job_id}/source/requirements.mdx"
          ],
          "condition": "input_mode == 'ui_form'",
          "min_mode": "lite"
        },
        {
          "id": "P0-04",
          "name": "Normalize Provided MDX",
          "description": "Validate and normalize directly provided MDX requirement.",
          "skill": "requirement-parse",
          "input": [
            "source/requirements.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/source/requirements.mdx"
          ],
          "condition": "input_mode == 'mdx'",
          "min_mode": "lite"
        }
      ]
    },
    {
      "id": "phase-1",
      "name": "Planning",
      "description": "From requirement source to reviewed specs and roadmap artifacts.",
      "execution": {
        "mode": "sequential_with_parallel_group"
      },
      "steps": [
        {
          "id": "P1-01",
          "name": "Find Existing Work",
          "description": "Discover related jobs, branches, specs, and reusable outputs.",
          "skill": "find-existing-work",
          "input": [
            "exports/jobs/index.json",
            "repo/specs/**",
            "repo/docs/**"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/existing-work.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-02",
          "name": "Update Capability Tree",
          "description": "Rebuild capability map using build-capability-tree.ts.",
          "skill": "build-capability-tree",
          "input": [
            "repo/specs/**",
            "repo/src/**"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-03",
          "name": "Create Job and Git Branch",
          "description": "Create job directory and working branch.",
          "skill": "job-create",
          "input": [
            "CCB_REQ_ID",
            "exports/jobs/{job_id}/analysis/existing-work.json",
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "output": [
            "exports/jobs/{job_id}/metadata.json",
            "git.branch.name"
          ],
          "condition": "done('P1-01') && done('P1-02')",
          "min_mode": "lite"
        },
        {
          "id": "P1-04",
          "name": "Convert MDX to OpenSpec",
          "description": "Generate OpenSpec from canonical requirements.mdx.",
          "skill": "mdx-to-openspec",
          "input": [
            "exports/jobs/{job_id}/source/requirements.mdx",
            "exports/jobs/{job_id}/metadata.json"
          ],
          "output": [
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P1-05",
          "name": "Review OpenSpec",
          "description": "Run multi-model review gate and auto-repair before passing.",
          "skill": "openspec-review",
          "input": [
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/openspec-review.json",
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          },
          "min_mode": "standard"
        },
        {
          "id": "P1-06",
          "name": "Parse OpenSpec to docs.json",
          "description": "Extract structured requirement docs from reviewed OpenSpec.",
          "skill": "parse-openspec",
          "input": [
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/docs.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-07",
          "name": "Check or Infer form.json",
          "description": "Use existing form.json when valid, otherwise infer it.",
          "skill": "infer-builder-config",
          "input": [
            "exports/jobs/{job_id}/parsed/docs.json",
            "source/form.json"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/form.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-08",
          "name": "Merge to unified.json",
          "description": "Merge docs.json and form.json into one execution model.",
          "skill": "merge-requirements",
          "input": [
            "exports/jobs/{job_id}/parsed/docs.json",
            "exports/jobs/{job_id}/parsed/form.json"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/unified.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-09",
          "name": "Analyze Capability Dependencies",
          "description": "Map feature requirements to capabilities and dependency graph.",
          "skill": "capability-analyze",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/capability-dependencies.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-10",
          "name": "Generate Development Specs",
          "description": "Generate detailed implementation specs under specs/.",
          "skill": "spec-generate",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/capability-dependencies.json"
          ],
          "output": [
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P1-11",
          "name": "Review Development Specs",
          "description": "Run multi-model quality gate and auto-repair for generated specs.",
          "skill": "specs-review",
          "input": [
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/specs-review.json",
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          },
          "min_mode": "standard"
        },
        {
          "id": "P1-12",
          "name": "Generate Global Roadmap View",
          "description": "Build cross-capability planning graph and milestones.",
          "skill": "roadmap-generate",
          "input": [
            "exports/jobs/{job_id}/analysis/capability-dependencies.json",
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/roadmap.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-13",
          "name": "Generate Planning Docs",
          "description": "Render planning documents from roadmap JSON to MDX.",
          "skill": "roadmap-docs-generate",
          "input": [
            "exports/jobs/{job_id}/analysis/roadmap.json"
          ],
          "output": [
            "exports/jobs/{job_id}/docs/roadmap.mdx"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-14",
          "name": "Commit Planning Changes",
          "description": "Commit planning artifacts to job branch.",
          "skill": "git-commit",
          "input": [
            "exports/jobs/{job_id}/**",
            "git.branch.name"
          ],
          "output": [
            "git.commit.planning"
          ],
          "min_mode": "lite"
        }
      ]
    },
    {
      "id": "phase-2",
      "name": "Execution",
      "description": "Execute and verify tasks in a loop until no task remains.",
      "execution": {
        "mode": "loop",
        "entry_step": "P2-15",
        "exit_condition": "tasks.remaining == 0"
      },
      "steps": [
        {
          "id": "P2-15",
          "name": "Execute Task",
          "description": "Implement next planned task from unified execution queue.",
          "skill": "task-execute",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/roadmap.json",
            "tasks.next"
          ],
          "output": [
            "workspace.code_changes",
            "tasks.current_result"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P2-16",
          "name": "Verify Task",
          "description": "Run automated checks for correctness and regressions.",
          "skill": "task-verify",
          "input": [
            "workspace.code_changes",
            "tasks.current_result"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/task-verify.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P2-17",
          "name": "Update OpenSpec Status",
          "description": "Reflect task completion and state in OpenSpec.",
          "skill": "task-update-status",
          "input": [
            "exports/jobs/{job_id}/source/openspec.mdx",
            "exports/jobs/{job_id}/reviews/task-verify.json"
          ],
          "output": [
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "condition": "task_verify.status == 'pass'",
          "min_mode": "standard"
        },
        {
          "id": "P2-18",
          "name": "Update Progress",
          "description": "Update progress metrics and execution tracking files.",
          "skill": "progress-update",
          "input": [
            "exports/jobs/{job_id}/source/openspec.mdx",
            "tasks.current_result"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/progress.json"
          ],
          "condition": "task_verify.status == 'pass'",
          "min_mode": "standard"
        },
        {
          "id": "P2-19",
          "name": "Commit Task Changes",
          "description": "Commit verified task changes on job branch.",
          "skill": "git-commit",
          "input": [
            "workspace.code_changes",
            "exports/jobs/{job_id}/analysis/progress.json"
          ],
          "output": [
            "git.commit.task"
          ],
          "condition": "task_verify.status == 'pass'",
          "min_mode": "lite"
        }
      ]
    },
    {
      "id": "phase-3",
      "name": "Acceptance",
      "description": "Multi-model acceptance gate followed by explicit human confirmation.",
      "execution": {
        "mode": "sequential"
      },
      "steps": [
        {
          "id": "P3-20",
          "name": "Multi-Model Acceptance Review",
          "description": "Run final acceptance review with auto-repair up to 3 attempts.",
          "skill": "acceptance-review",
          "input": [
            "workspace.final_changes",
            "exports/jobs/{job_id}/source/openspec.mdx",
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/acceptance-review.json",
            "workspace.final_changes"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true,
              "user_options": [
                "continue",
                "cancel"
              ]
            }
          },
          "min_mode": "standard"
        },
        {
          "id": "P3-21",
          "name": "Human Final Confirmation",
          "description": "Require explicit human decision before merge and archive.",
          "skill": "human-confirm",
          "input": [
            "exports/jobs/{job_id}/reviews/acceptance-review.json"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/human-approval.json"
          ],
          "min_mode": "lite"
        }
      ]
    },
    {
      "id": "phase-4",
      "name": "Archive",
      "description": "Merge, archive artifacts, refresh docs/spec snapshots, and rebuild capability tree.",
      "execution": {
        "mode": "sequential"
      },
      "steps": [
        {
          "id": "P4-22",
          "name": "Merge Git Branch",
          "description": "Merge approved job branch into target integration branch.",
          "skill": "git-merge-branch",
          "input": [
            "git.branch.name",
            "exports/jobs/{job_id}/reviews/human-approval.json"
          ],
          "output": [
            "git.merge.commit"
          ],
          "condition": "human_approved == true",
          "min_mode": "lite"
        },
        {
          "id": "P4-23",
          "name": "Archive OpenSpec",
          "description": "Archive OpenSpec and related review artifacts.",
          "skill": "openspec-archive",
          "input": [
            "exports/jobs/{job_id}/source/openspec.mdx",
            "exports/jobs/{job_id}/reviews/*.json"
          ],
          "output": [
            "exports/archive/openspec/{job_id}.mdx"
          ],
          "min_mode": "full"
        },
        {
          "id": "P4-24",
          "name": "Update specs/",
          "description": "Refresh repository-level specs from approved job specs.",
          "skill": "spec-generate",
          "input": [
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "output": [
            "repo/specs/**"
          ],
          "min_mode": "full"
        },
        {
          "id": "P4-25",
          "name": "Update Development Docs",
          "description": "Regenerate development documentation after merge.",
          "skill": "docs-generate",
          "input": [
            "repo/specs/**",
            "workspace.final_changes"
          ],
          "output": [
            "repo/docs/**"
          ],
          "min_mode": "full"
        },
        {
          "id": "P4-26",
          "name": "Update Roadmap Docs",
          "description": "Regenerate roadmap docs for latest merged state.",
          "skill": "roadmap-docs-generate",
          "input": [
            "exports/jobs/{job_id}/analysis/roadmap.json",
            "repo/specs/**"
          ],
          "output": [
            "repo/docs/roadmap/**"
          ],
          "min_mode": "full"
        },
        {
          "id": "P4-27",
          "name": "Rebuild Capability Tree",
          "description": "Rebuild capability tree after merge and docs/spec updates.",
          "skill": "build-capability-tree",
          "input": [
            "repo/specs/**",
            "repo/src/**"
          ],
          "output": [
            "repo/.ccb/capability-tree.json"
          ],
          "min_mode": "full"
        }
      ]
    }
  ],
  "transitions": [
    {
      "from": "P0-01",
      "to": "P0-02"
    },
    {
      "from": "P0-02",
      "to": "P0-03",
      "condition": "input_mode == 'ui_form'"
    },
    {
      "from": "P0-02",
      "to": "P0-04",
      "condition": "input_mode == 'mdx'"
    },
    {
      "from": "P0-03",
      "to": "P1-01"
    },
    {
      "from": "P0-03",
      "to": "P1-02"
    },
    {
      "from": "P0-04",
      "to": "P1-01"
    },
    {
      "from": "P0-04",
      "to": "P1-02"
    },
    {
      "from": "P1-01",
      "to": "P1-03",
      "condition": "done('P1-02')"
    },
    {
      "from": "P1-02",
      "to": "P1-03",
      "condition": "done('P1-01')"
    },
    {
      "from": "P1-03",
      "to": "P1-04"
    },
    {
      "from": "P1-04",
      "to": "P1-05"
    },
    {
      "from": "P1-05",
      "to": "P1-06",
      "condition": "review_passed('P1-05')"
    },
    {
      "from": "P1-06",
      "to": "P1-07"
    },
    {
      "from": "P1-07",
      "to": "P1-08"
    },
    {
      "from": "P1-08",
      "to": "P1-09"
    },
    {
      "from": "P1-09",
      "to": "P1-10"
    },
    {
      "from": "P1-10",
      "to": "P1-11"
    },
    {
      "from": "P1-11",
      "to": "P1-12",
      "condition": "review_passed('P1-11')"
    },
    {
      "from": "P1-12",
      "to": "P1-13"
    },
    {
      "from": "P1-13",
      "to": "P1-14"
    },
    {
      "from": "P1-14",
      "to": "P2-15"
    },
    {
      "from": "P2-15",
      "to": "P2-16"
    },
    {
      "from": "P2-16",
      "to": "P2-15",
      "condition": "task_verify.status == 'fail'"
    },
    {
      "from": "P2-16",
      "to": "P2-17",
      "condition": "task_verify.status == 'pass'"
    },
    {
      "from": "P2-17",
      "to": "P2-18"
    },
    {
      "from": "P2-18",
      "to": "P2-19"
    },
    {
      "from": "P2-19",
      "to": "P2-15",
      "condition": "tasks.remaining > 0"
    },
    {
      "from": "P2-19",
      "to": "P3-20",
      "condition": "tasks.remaining == 0"
    },
    {
      "from": "P3-20",
      "to": "P3-20",
      "condition": "review_failed('P3-20') && auto_repair_attempts < 3"
    },
    {
      "from": "P3-20",
      "to": "P3-21",
      "condition": "review_passed('P3-20')"
    },
    {
      "from": "P3-20",
      "to": "P3-21",
      "condition": "review_failed('P3-20') && auto_repair_attempts == 3 && user_decision == 'continue'"
    },
    {
      "from": "P3-20",
      "to": "END",
      "condition": "review_failed('P3-20') && auto_repair_attempts == 3 && user_decision == 'cancel'"
    },
    {
      "from": "P3-21",
      "to": "P4-22",
      "condition": "human_approved == true"
    },
    {
      "from": "P3-21",
      "to": "END",
      "condition": "human_approved == false"
    },
    {
      "from": "P4-22",
      "to": "P4-23"
    },
    {
      "from": "P4-23",
      "to": "P4-24"
    },
    {
      "from": "P4-24",
      "to": "P4-25"
    },
    {
      "from": "P4-25",
      "to": "P4-26"
    },
    {
      "from": "P4-26",
      "to": "P4-27"
    },
    {
      "from": "P4-27",
      "to": "END"
    }
  ]
}