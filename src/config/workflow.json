{
  "$schema": "https://product-builder.dev/schemas/workflow.v1.json",
  "version": "1.0.0",
  "workflow_id": "product-builder-cli-standard",
  "name": "Product Builder CLI End-to-End Workflow",
  "description": "Five-phase workflow with conditional branching, parallel steps, task-loop execution, and multi-model review auto-repair.",
  "mode": "full",
  "available_modes": {
    "full": {
      "label": "Full",
      "required_tools": [
        "ccb",
        "cca",
        "ralph",
        "openclaw"
      ],
      "description": "Complete workflow with automatic loop (Phase 2 uses ralph), multi-model review, and all automation. Openclaw is experimental top-level monitoring.",
      "steps": 54,
      "review_gates": 3,
      "enabled_steps": [
        "P0-01", "P0-02", "P0-03", "P0-04", "P0-05", "P0-06", "P0-07", "P0-08", "P0-09", "P0-10", "P0-11", "P0-12",
        "P1-01", "P1-02", "P1-03", "P1-04", "P1-05", "P1-06", "P1-07", "P1-08", "P1-09", "P1-10", "P1-11", "P1-12", "P1-13", "P1-14", "P1-15",
        "P2-11", "P2-11a", "P2-12", "P2-13", "P2-14", "P2-15", "P2-16", "P2-17", "P2-18",
        "P3-19", "P3-20", "P3-21", "P3-22", "P3-23", "P3-24",
        "P4-22", "P4-23", "P4-24", "P4-25", "P4-26", "P4-27", "P4-28", "P4-29", "P4-30", "P4-31", "P4-32", "P4-33"
      ]
    },
    "standard": {
      "label": "Standard",
      "required_tools": [
        "ccb",
        "cca"
      ],
      "description": "Multi-model review with ccb/cca, manual execution, no automatic loop",
      "steps": 48,
      "review_gates": 3,
      "enabled_steps": [
        "P0-01", "P0-02", "P0-03", "P0-04", "P0-08", "P0-09", "P0-10", "P0-11", "P0-12",
        "P1-01", "P1-02", "P1-03", "P1-04", "P1-05", "P1-06", "P1-07", "P1-08", "P1-09", "P1-10", "P1-11", "P1-12", "P1-13", "P1-14", "P1-15",
        "P2-11a", "P2-13", "P2-14", "P2-15", "P2-16", "P2-17", "P2-18",
        "P3-19", "P3-20", "P3-21", "P3-22", "P3-23", "P3-24",
        "P4-22", "P4-23", "P4-24", "P4-25", "P4-26", "P4-27", "P4-28", "P4-29", "P4-30", "P4-31", "P4-32", "P4-33"
      ]
    },
    "lite": {
      "label": "Lite",
      "required_tools": [],
      "description": "Single CLI, minimal workflow, manual execution required",
      "steps": 12,
      "review_gates": 0,
      "enabled_steps": [
        "P0-01", "P0-02", "P0-08", "P0-11",
        "P1-03", "P1-04", "P1-10", "P1-14",
        "P2-13",
        "P3-22", "P3-23",
        "P4-22"
      ]
    }
  },
  "metadata": {
    "owner": "product-builder-cli",
    "created_at": "2026-02-17",
    "job_id_format": "YYYY-MM-DD-HHMM-name",
    "job_root": "exports/jobs/{job_id}/",
    "supported_input_modes": [
      "mdx",
      "ui_form"
    ],
    "tools": {
      "ccb": {
        "description": "Primary LLM CLI for task execution",
        "required_for": ["standard", "full"]
      },
      "cca": {
        "description": "Secondary LLM CLI for multi-model review",
        "required_for": ["standard", "full"]
      },
      "ralph": {
        "description": "Phase 2 execution loop controller",
        "required_for": ["full"],
        "usage": "Manages automatic task loop in Phase 2"
      },
      "openclaw": {
        "description": "Experimental top-level LLM monitoring (optional)",
        "required_for": [],
        "status": "experimental",
        "usage": "Monitors all tmux terminal windows and unified requirement dispatch",
        "note": "Not yet tested, will be configured last"
      }
    }
  },
  "job_structure": {
    "required_dirs": [
      "exports/jobs/{job_id}/source",
      "exports/jobs/{job_id}/parsed",
      "exports/jobs/{job_id}/analysis",
      "exports/jobs/{job_id}/reviews",
      "exports/jobs/{job_id}/specs"
    ],
    "required_files": [
      "exports/jobs/{job_id}/metadata.json"
    ]
  },
  "review_policy_defaults": {
    "models": [
      "gemini",
      "claude",
      "codex"
    ],
    "pass_threshold": 0.75,
    "max_critical": 0,
    "max_medium": 2,
    "auto_repair": {
      "enabled": true,
      "max_attempts": 3,
      "ask_user_on_exhausted": true,
      "user_options": [
        "continue",
        "cancel"
      ]
    }
  },
  "cli_view": {
    "default_group_by": "phase",
    "show_step_fields": [
      "id",
      "name",
      "skill",
      "condition",
      "review_config"
    ],
    "show_transitions": true
  },
  "phases": [
    {
      "id": "phase-0",
      "name": "Requirement Research & Analysis",
      "description": "From user requirements to standardized MDX requirement documents",
      "execution": {
        "mode": "sequential"
      },
      "steps": [
        {
          "id": "P0-01",
          "name": "Collect User Requirement",
          "description": "Extract scope, constraints, and acceptance hints from user input",
          "input": [
            "user_input.raw"
          ],
          "output": [
            "exports/jobs/{job_id}/source/raw-requirement.txt"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P0-02",
          "name": "Detect Requirement Type",
          "description": "Determine whether requirement is brief (one sentence) or detailed (with planning)",
          "input": [
            "exports/jobs/{job_id}/source/raw-requirement.txt"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/requirement-type.json"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P0-03",
          "name": "Requirement Clarification",
          "description": "Ask about target users, core problems, key features, and constraints",
          "input": [
            "exports/jobs/{job_id}/source/raw-requirement.txt"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/clarified-requirement.md"
          ],
          "condition": "when_requirement_brief",
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ]
        },
        {
          "id": "P0-04",
          "name": "Requirement Expansion",
          "description": "Expand brief requirement into detailed description",
          "input": [
            "exports/jobs/{job_id}/parsed/clarified-requirement.md"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/expanded-requirement.md"
          ],
          "condition": "when_requirement_brief",
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ]
        },
        {
          "id": "P0-05",
          "name": "Competitor Research",
          "description": "Use web_search and context7 to find competitors",
          "input": [
            "exports/jobs/{job_id}/parsed/expanded-requirement.md"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/competitor-list.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ],
          "optional_tools": [
            "web_search",
            "context7"
          ]
        },
        {
          "id": "P0-06",
          "name": "Competitor Analysis",
          "description": "Analyze feature comparison, pricing, user reviews, and market positioning",
          "input": [
            "exports/jobs/{job_id}/analysis/competitor-list.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/competitor-analysis.md"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ]
        },
        {
          "id": "P0-07",
          "name": "Market Positioning",
          "description": "Determine differentiation advantages and target market",
          "input": [
            "exports/jobs/{job_id}/analysis/competitor-analysis.md"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/market-positioning.md"
          ],
          "min_mode": "full",
          "required_tools": [
            "ccb"
          ]
        },
        {
          "id": "P0-08",
          "name": "Feature Breakdown",
          "description": "Break down core features and sub-features",
          "input": [
            "exports/jobs/{job_id}/parsed/expanded-requirement.md"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ]
        },
        {
          "id": "P0-09",
          "name": "User Story Generation",
          "description": "Generate user stories and usage scenarios",
          "input": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/user-stories.md"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ]
        },
        {
          "id": "P0-10",
          "name": "Technical Feasibility Analysis",
          "description": "Evaluate tech stack, dependencies, and risks",
          "input": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/feasibility-analysis.md"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb"
          ]
        },
        {
          "id": "P0-11",
          "name": "Generate Requirement MDX",
          "description": "Integrate all analysis results into requirement MDX",
          "input": [
            "exports/jobs/{job_id}/analysis/feature-breakdown.json",
            "exports/jobs/{job_id}/analysis/user-stories.md",
            "exports/jobs/{job_id}/analysis/feasibility-analysis.md"
          ],
          "output": [
            "exports/jobs/{job_id}/source/requirement.mdx"
          ],
          "min_mode": "lite",
          "required_tools": [
            "ccb"
          ]
        },
        {
          "id": "P0-12",
          "name": "Review Requirement MDX",
          "description": "Multi-model review with auto-repair (up to 3 attempts)",
          "requires_human_approval": true,
          "input": [
            "exports/jobs/{job_id}/source/requirement.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/source/requirement.mdx",
            "exports/jobs/{job_id}/reviews/requirement-review.json"
          ],
          "min_mode": "standard",
          "required_tools": [
            "ccb",
            "cca"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          }
        }
      ],
      "groups": [
        {
          "id": "0.1",
          "name": "Initial Requirement Collection",
          "description": "Initial requirement collection",
          "step_ids": [
            "P0-01",
            "P0-02",
            "P0-03",
            "P0-04"
          ]
        },
        {
          "id": "0.2",
          "name": "Market Research",
          "description": "Market research",
          "step_ids": [
            "P0-05",
            "P0-06",
            "P0-07"
          ]
        },
        {
          "id": "0.3",
          "name": "Requirement Analysis",
          "description": "Requirement analysis",
          "step_ids": [
            "P0-08",
            "P0-09",
            "P0-10"
          ]
        },
        {
          "id": "0.4",
          "name": "MDX Generation",
          "description": "MDX generation",
          "step_ids": [
            "P0-11",
            "P0-12"
          ]
        }
      ]
    },
    {
      "id": "phase-1",
      "name": "Planning",
      "description": "From requirement source to reviewed specs and roadmap artifacts.",
      "execution": {
        "mode": "sequential_with_parallel_group"
      },
      "steps": [
        {
          "id": "P1-01",
          "name": "Find Existing Work",
          "description": "Discover related jobs, branches, specs, and reusable outputs.",
          "input": [
            "exports/jobs/index.json",
            "repo/specs/**",
            "repo/docs/**"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/existing-work.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-02",
          "name": "Update Capability Tree",
          "description": "Rebuild capability map using build-capability-tree.ts.",
          "input": [
            "repo/specs/**",
            "repo/src/**"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-03",
          "name": "Create Job and Git Branch",
          "description": "Create job directory and working branch.",
          "input": [
            "CCB_REQ_ID",
            "exports/jobs/{job_id}/analysis/existing-work.json",
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "output": [
            "exports/jobs/{job_id}/metadata.json",
            "git.branch.name"
          ],
          "condition": "after_p1_01_and_p1_02",
          "min_mode": "lite"
        },
        {
          "id": "P1-04",
          "name": "Convert MDX to OpenSpec",
          "description": "Generate OpenSpec from canonical requirements.mdx.",
          "input": [
            "exports/jobs/{job_id}/source/requirements.mdx",
            "exports/jobs/{job_id}/metadata.json"
          ],
          "output": [
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P1-05",
          "name": "Review OpenSpec",
          "description": "Run multi-model review gate and auto-repair before passing.",
          "input": [
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/openspec-review.json",
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          },
          "min_mode": "standard",
          "required_tools": [
            "ccb",
            "cca"
          ]
        },
        {
          "id": "P1-06",
          "name": "Parse OpenSpec to docs.json",
          "description": "Extract structured requirement docs from reviewed OpenSpec.",
          "input": [
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/docs.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-07",
          "name": "Check or Infer form.json",
          "description": "Use existing form.json when valid, otherwise infer it.",
          "input": [
            "exports/jobs/{job_id}/parsed/docs.json",
            "source/form.json"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/form.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-08",
          "name": "Merge to unified.json",
          "description": "Merge docs.json and form.json into one execution model.",
          "input": [
            "exports/jobs/{job_id}/parsed/docs.json",
            "exports/jobs/{job_id}/parsed/form.json"
          ],
          "output": [
            "exports/jobs/{job_id}/parsed/unified.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-09",
          "name": "Analyze Capability Dependencies",
          "description": "Map feature requirements to capabilities and dependency graph.",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/capability-tree.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/capability-dependencies.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-10",
          "name": "Generate Development Specs",
          "description": "Generate detailed implementation specs under specs/.",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/capability-dependencies.json"
          ],
          "output": [
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P1-11",
          "name": "Review Development Specs",
          "description": "Run multi-model quality gate and auto-repair for generated specs.",
          "input": [
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/specs-review.json",
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true
            }
          },
          "min_mode": "standard",
          "required_tools": [
            "ccb",
            "cca"
          ]
        },
        {
          "id": "P1-12",
          "name": "Generate Global Roadmap View",
          "description": "Build cross-capability planning graph and milestones.",
          "input": [
            "exports/jobs/{job_id}/analysis/capability-dependencies.json",
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/roadmap.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-13",
          "name": "Generate Planning Docs",
          "description": "Render planning documents from roadmap JSON to MDX.",
          "input": [
            "exports/jobs/{job_id}/analysis/roadmap.json"
          ],
          "output": [
            "exports/jobs/{job_id}/docs/roadmap.mdx"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P1-14",
          "name": "Commit Planning Changes",
          "description": "Commit planning artifacts to job branch.",
          "input": [
            "exports/jobs/{job_id}/**",
            "git.branch.name"
          ],
          "output": [
            "git.commit.planning"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P1-15",
          "name": "Review Planning Results",
          "description": "User reviews planning artifacts and decides whether to proceed with execution.",
          "input": [
            "exports/jobs/{job_id}/docs/roadmap.mdx",
            "exports/jobs/{job_id}/specs/*.mdx",
            "exports/jobs/{job_id}/analysis/roadmap.json"
          ],
          "output": [
            "user_decision.proceed"
          ],
          "requires_human_approval": true,
          "min_mode": "lite"
        }
      ],
      "groups": [
        {
          "id": "1.1",
          "name": "Capability Analysis",
          "description": "Capability analysis",
          "step_ids": [
            "P1-01",
            "P1-02",
            "P1-03"
          ]
        },
        {
          "id": "1.2",
          "name": "OpenSpec Generation",
          "description": "OpenSpec generation",
          "step_ids": [
            "P1-04",
            "P1-05",
            "P1-06"
          ]
        },
        {
          "id": "1.3",
          "name": "Development Specs",
          "description": "Development specs generation",
          "step_ids": [
            "P1-07",
            "P1-08",
            "P1-09",
            "P1-10",
            "P1-11",
            "P1-12",
            "P1-13",
            "P1-14"
          ]
        }
      ]
    },
    {
      "id": "phase-2",
      "name": "Execution",
      "description": "Execute tasks in a loop with automated testing and repair for each task until all tasks are completed.",
      "execution": {
        "mode": "loop",
        "entry_step": "P2-11",
        "exit_condition": "all_tasks_done"
      },
      "steps": [
        {
          "id": "P2-11",
          "name": "Start Execution Decision",
          "description": "User decides whether to start execution or wait.",
          "input": [
            "exports/jobs/{job_id}/docs/roadmap.mdx",
            "user_decision.proceed"
          ],
          "output": [
            "execution.started"
          ],
          "requires_human_approval": true,
          "min_mode": "lite"
        },
        {
          "id": "P2-11a",
          "name": "Create GitHub Issue",
          "description": "Create GitHub issue to track this job. Link issue to branch and record issue number.",
          "input": [
            "exports/jobs/{job_id}/metadata.json",
            "git.branch.name",
            "exports/jobs/{job_id}/docs/roadmap.mdx"
          ],
          "output": [
            "github.issue.number",
            "github.issue.url"
          ],
          "min_mode": "standard",
          "required_tools": [
            "gh"
          ]
        },
        {
          "id": "P2-12",
          "name": "Get Next Task",
          "description": "Retrieve next executable task from queue, checking blockedBy dependencies.",
          "input": [
            "exports/jobs/{job_id}/parsed/unified.json",
            "exports/jobs/{job_id}/analysis/progress.json"
          ],
          "output": [
            "tasks.current"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P2-13",
          "name": "Execute Task",
          "description": "AI Agent implements the current task.",
          "input": [
            "tasks.current",
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "output": [
            "workspace.code_changes"
          ],
          "condition": "has_executable_task",
          "min_mode": "lite"
        },
        {
          "id": "P2-14",
          "name": "Auto Test",
          "description": "Run automated tests from verification.json.",
          "input": [
            "workspace.code_changes",
            "exports/jobs/{job_id}/specs/verification.json"
          ],
          "output": [
            "test.results"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P2-15",
          "name": "Fix Issue",
          "description": "Fix issues found during testing. Add comment to GitHub Issue tracking the fix attempt.",
          "input": [
            "test.results",
            "workspace.code_changes",
            "github.issue.number"
          ],
          "output": [
            "workspace.code_changes"
          ],
          "condition": "test_failed",
          "min_mode": "lite",
          "required_tools": [
            "gh"
          ]
        },
        {
          "id": "P2-16",
          "name": "Update OpenSpec",
          "description": "Mark task as completed in tasks.md.",
          "input": [
            "tasks.current",
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "condition": "test_passed",
          "min_mode": "standard"
        },
        {
          "id": "P2-17",
          "name": "Update Progress",
          "description": "Update progress.json with task completion status.",
          "input": [
            "tasks.current",
            "exports/jobs/{job_id}/analysis/progress.json"
          ],
          "output": [
            "exports/jobs/{job_id}/analysis/progress.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P2-18",
          "name": "Commit Task",
          "description": "Commit task changes to job branch (frontend/backend/OpenSpec).",
          "input": [
            "workspace.code_changes",
            "exports/jobs/{job_id}/source/openspec.mdx",
            "exports/jobs/{job_id}/analysis/progress.json"
          ],
          "output": [
            "git.commit.task"
          ],
          "min_mode": "lite"
        }
      ],
      "groups": [
        {
          "id": "2.1",
          "name": "Execution Start",
          "description": "User decision to start execution",
          "step_ids": [
            "P2-11"
          ]
        },
        {
          "id": "2.2",
          "name": "Task Loop",
          "description": "Task execution loop with testing and fixes",
          "step_ids": [
            "P2-12",
            "P2-13",
            "P2-14",
            "P2-15",
            "P2-16",
            "P2-17",
            "P2-18"
          ]
        }
      ]
    },
    {
      "id": "phase-3",
      "name": "Acceptance",
      "description": "Final acceptance with multi-model review and human confirmation before archiving.",
      "execution": {
        "mode": "sequential"
      },
      "steps": [
        {
          "id": "P3-19",
          "name": "Final Review",
          "description": "Multi-model review gate for final acceptance of all completed work.",
          "input": [
            "workspace.all_changes",
            "exports/jobs/{job_id}/specs/*.mdx"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/final-review.json"
          ],
          "review_config": {
            "models": [
              "gemini",
              "claude",
              "codex"
            ],
            "pass_threshold": 0.75,
            "max_critical": 0,
            "max_medium": 2,
            "auto_repair": {
              "enabled": true,
              "max_attempts": 3,
              "ask_user_on_exhausted": true,
              "user_options": [
                "retry_phase2",
                "continue"
              ]
            }
          },
          "min_mode": "standard",
          "required_tools": [
            "ccb",
            "cca"
          ]
        },
        {
          "id": "P3-20",
          "name": "Aggregate Review Results",
          "description": "Aggregate multi-model review results and calculate pass rate.",
          "input": [
            "exports/jobs/{job_id}/reviews/final-review.json"
          ],
          "output": [
            "exports/jobs/{job_id}/reviews/final-review-aggregated.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P3-21",
          "name": "Auto Fix",
          "description": "Automatically fix issues found in review (max 3 attempts). Add comment to GitHub Issue tracking the fix attempt. If exhausted, return to Phase 2.",
          "input": [
            "exports/jobs/{job_id}/reviews/final-review-aggregated.json",
            "workspace.all_changes",
            "github.issue.number"
          ],
          "output": [
            "workspace.all_changes"
          ],
          "condition": "review_needs_fix",
          "min_mode": "standard",
          "required_tools": [
            "gh"
          ]
        },
        {
          "id": "P3-22",
          "name": "Record Technical Debt",
          "description": "Record issues to TECHNICAL_DEBT.md if review passed with minor issues.",
          "input": [
            "exports/jobs/{job_id}/reviews/final-review-aggregated.json"
          ],
          "output": [
            "exports/jobs/{job_id}/TECHNICAL_DEBT.md"
          ],
          "condition": "review_passed_with_issues",
          "min_mode": "standard"
        },
        {
          "id": "P3-23",
          "name": "Human Final Confirmation",
          "description": "Final human approval to proceed with archiving and deployment. Only executed after machine review passes.",
          "input": [
            "exports/jobs/{job_id}/reviews/final-review-aggregated.json",
            "exports/jobs/{job_id}/TECHNICAL_DEBT.md",
            "workspace.all_changes"
          ],
          "output": [
            "human_approval.final"
          ],
          "requires_human_approval": true,
          "condition": "review_passed",
          "min_mode": "lite"
        },
        {
          "id": "P3-24",
          "name": "Create Pull Request",
          "description": "Create GitHub Pull Request for code review. Link to issue and include review results.",
          "input": [
            "git.branch.name",
            "github.issue.number",
            "exports/jobs/{job_id}/reviews/final-review-aggregated.json",
            "exports/jobs/{job_id}/TECHNICAL_DEBT.md"
          ],
          "output": [
            "github.pr.number",
            "github.pr.url"
          ],
          "min_mode": "standard",
          "required_tools": [
            "gh"
          ]
        }
      ],
      "groups": [
        {
          "id": "3.1",
          "name": "Machine Review",
          "description": "Multi-model review with auto-repair",
          "step_ids": [
            "P3-19",
            "P3-20",
            "P3-21",
            "P3-22"
          ]
        },
        {
          "id": "3.2",
          "name": "Human Approval",
          "description": "Final human approval gate",
          "step_ids": [
            "P3-23"
          ]
        },
        {
          "id": "3.3",
          "name": "Pull Request",
          "description": "Create GitHub Pull Request",
          "step_ids": [
            "P3-24"
          ]
        }
      ]
    },
    {
      "id": "phase-4",
      "name": "Archive",
      "description": "Archive OpenSpec, update documentation, and rebuild capability tree.",
      "execution": {
        "mode": "sequential"
      },
      "steps": [
        {
          "id": "P4-22",
          "name": "Merge Git Branch",
          "description": "Merge feature branch to main (frontend + backend).",
          "input": [
            "git.branch.name",
            "human_approval.final"
          ],
          "output": [
            "git.merge.result"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P4-23",
          "name": "Archive OpenSpec",
          "description": "Archive OpenSpec to openspec repository.",
          "input": [
            "exports/jobs/{job_id}/source/openspec.mdx"
          ],
          "output": [
            "openspec.archived_path"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P4-24",
          "name": "Commit Archive",
          "description": "Commit archived OpenSpec to openspec repository.",
          "input": [
            "openspec.archived_path"
          ],
          "output": [
            "git.commit.archive"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P4-25",
          "name": "Update Specs",
          "description": "Apply changes to capability specifications in specs/.",
          "input": [
            "exports/jobs/{job_id}/specs/*.mdx",
            "repo/specs/**"
          ],
          "output": [
            "repo/specs/**"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P4-26",
          "name": "Commit Specs",
          "description": "Commit updated specs to waoooo-docs repository.",
          "input": [
            "repo/specs/**"
          ],
          "output": [
            "git.commit.specs"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P4-27",
          "name": "Update Development Docs",
          "description": "Generate and update capability documentation.",
          "input": [
            "repo/specs/**"
          ],
          "output": [
            "repo/docs/**"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P4-28",
          "name": "Commit Docs",
          "description": "Commit updated documentation to waoooo-docs repository.",
          "input": [
            "repo/docs/**"
          ],
          "output": [
            "git.commit.docs"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P4-29",
          "name": "Update Roadmap Docs",
          "description": "Update planning documents (JSON → MDX final state).",
          "input": [
            "exports/jobs/{job_id}/analysis/roadmap.json"
          ],
          "output": [
            "repo/docs/roadmap/**"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P4-30",
          "name": "Commit Roadmap",
          "description": "Commit updated roadmap documents to waoooo-docs repository.",
          "input": [
            "repo/docs/roadmap/**"
          ],
          "output": [
            "git.commit.roadmap"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P4-31",
          "name": "Rebuild Capability Tree",
          "description": "Rebuild capability tree using build-capability-tree.ts.",
          "input": [
            "repo/specs/**",
            "repo/src/**"
          ],
          "output": [
            "repo/capability-tree.json"
          ],
          "min_mode": "standard"
        },
        {
          "id": "P4-32",
          "name": "Commit Capability Tree",
          "description": "Commit updated capability tree to waoooo-web repository.",
          "input": [
            "repo/capability-tree.json"
          ],
          "output": [
            "git.commit.capability_tree"
          ],
          "min_mode": "lite"
        },
        {
          "id": "P4-33",
          "name": "Create Release",
          "description": "Create GitHub Release with changelog and version tag.",
          "input": [
            "github.pr.number",
            "git.merge.result",
            "exports/jobs/{job_id}/metadata.json"
          ],
          "output": [
            "github.release.tag",
            "github.release.url"
          ],
          "min_mode": "standard",
          "required_tools": [
            "gh"
          ]
        }
      ],
      "groups": [
        {
          "id": "4.1",
          "name": "Merge and Archive",
          "description": "Merge branch and archive OpenSpec",
          "step_ids": [
            "P4-22",
            "P4-23",
            "P4-24"
          ]
        },
        {
          "id": "4.2",
          "name": "Update Documentation",
          "description": "Update specs, docs, and roadmap",
          "step_ids": [
            "P4-25",
            "P4-26",
            "P4-27",
            "P4-28",
            "P4-29",
            "P4-30"
          ]
        },
        {
          "id": "4.3",
          "name": "Rebuild Capability Tree",
          "description": "Rebuild and commit capability tree",
          "step_ids": [
            "P4-31",
            "P4-32"
          ]
        },
        {
          "id": "4.4",
          "name": "Create Release",
          "description": "Create GitHub Release",
          "step_ids": [
            "P4-33"
          ]
        }
      ]
    }
